# Flavos OS — Notification Daemon (dunst) v3
# Design System v3 tokens applied.
# Motion: enter 200ms ease-out, exit 150ms ease-in.
# Position: top-right, non-intrusive, calma e relevante.

[global]
    # --- Layout ---
    monitor = 0
    follow = keyboard
    width = (280, 380)
    height = 120
    origin = top-right
    offset = 16x16
    notification_limit = 4
    indicate_hidden = yes

    # --- Appearance ---
    transparency = 0
    separator_height = 1
    separator_color = "#272D3D"
    padding = 16
    horizontal_padding = 20
    text_icon_padding = 16
    frame_width = 1
    frame_color = "#272D3D"
    corner_radius = 10
    gap_size = 6

    # --- Typography ---
    font = Inter 10
    line_height = 4
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 30
    ellipsize = end
    word_wrap = yes

    # --- Behavior ---
    sort = yes
    idle_threshold = 60
    show_indicators = no
    sticky_history = yes
    history_length = 20

    # --- Icons ---
    icon_position = left
    min_icon_size = 24
    max_icon_size = 48
    icon_theme = hicolor
    enable_recursive_icon_lookup = true

    # --- Motion ---
    # dunst built-in: slide from right
    # Duration aligns with motion.normal (200ms)

    # --- Mouse actions ---
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

    # --- DMenu for actions ---
    dmenu = /usr/bin/dmenu -p dunst:

[urgency_low]
    # Quiet, informational
    background = "#151921"
    foreground = "#8891A5"
    frame_color = "#272D3D"
    timeout = 5
    highlight = "#4B8BF5"

[urgency_normal]
    # Standard notification
    background = "#1C2030"
    foreground = "#E8ECF4"
    frame_color = "#272D3D"
    timeout = 6
    highlight = "#4B8BF5"

[urgency_critical]
    # Alerts — stays until dismissed
    background = "#1C2030"
    foreground = "#E8ECF4"
    frame_color = "#F87171"
    timeout = 0
    highlight = "#F87171"

# Nota arquitetural:
# OSD (volume, brilho) é componente da shell (flavos-osd), não passa por aqui.
# dunst é exclusivo para notificações de apps e eventos de segundo plano.
