# Flavos OS — User MIME defaults
# Location: ~/.config/mimeapps.list (via skel)
#
# Espelha /etc/xdg/mimeapps.list no estado inicial.
# O usuario pode editar este arquivo sem afetar o nivel de sistema.
#
# [Added Associations] nao utilizado: as entradas MimeType= nos .desktop
# files ja garantem a presenca dos apps no menu "Abrir com" do Nemo.

[Default Applications]
# --- Web e links ---
x-scheme-handler/http=firefox-esr.desktop
x-scheme-handler/https=firefox-esr.desktop
x-scheme-handler/ftp=firefox-esr.desktop
text/html=firefox-esr.desktop

# --- Diretorios ---
inode/directory=flavos-files.desktop

# --- Texto ---
text/plain=flavos-text.desktop

# --- Imagens ---
image/jpeg=flavos-image.desktop
image/png=flavos-image.desktop
image/webp=flavos-image.desktop
image/gif=flavos-image.desktop
image/svg+xml=flavos-image.desktop
image/bmp=flavos-image.desktop
image/tiff=flavos-image.desktop

# --- PDF (Etapa 12D) ---
application/pdf=flavos-pdf.desktop

# --- Video (Etapa 12D) ---
video/mp4=flavos-media.desktop
video/webm=flavos-media.desktop
video/x-matroska=flavos-media.desktop
video/x-msvideo=flavos-media.desktop
video/ogg=flavos-media.desktop
video/quicktime=flavos-media.desktop

# --- Audio (Etapa 12D) ---
audio/mpeg=flavos-media.desktop
audio/flac=flavos-media.desktop
audio/ogg=flavos-media.desktop
audio/wav=flavos-media.desktop
audio/x-vorbis+ogg=flavos-media.desktop
audio/aac=flavos-media.desktop
audio/mp4=flavos-media.desktop

# --- Arquivos Compactados (Etapa 13A) ---
application/zip=flavos-archive.desktop
application/x-7z-compressed=flavos-archive.desktop
application/x-tar=flavos-archive.desktop
application/gzip=flavos-archive.desktop
application/x-xz=flavos-archive.desktop
application/x-compressed-tar=flavos-archive.desktop
application/x-xz-compressed-tar=flavos-archive.desktop
application/x-bzip2-compressed-tar=flavos-archive.desktop
application/vnd.rar=flavos-archive.desktop
application/x-rar=flavos-archive.desktop
application/x-rar-compressed=flavos-archive.desktop
