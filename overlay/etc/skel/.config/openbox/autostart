# ~/.config/openbox/autostart
# Flavos OS — Shell Visual (Etapa 9B)
# Lançado pelo openbox-session. Inicializa os componentes visuais.

# 1. Wallpaper
feh --bg-fill /usr/share/flavos/wallpaper.jpeg &

# 2. Compositor e Motion Design
picom -b

# 3. Painel (tint2)
tint2 &

# 4. Servidor de Notificações (dunst)
dunst &

# 5. Agente de Autorização
lxpolkit &

# 5. Terminal inicial desativado na Etapa 9E (onboarding limpo)
# sleep 0.5
# lxterminal &
