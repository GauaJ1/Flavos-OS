<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <resistance>
    <strength>10</strength>
    <screen_edge_strength>20</screen_edge_strength>
  </resistance>
  <margins>
    <top>32</top>
    <bottom>36</bottom>
    <left>0</left>
    <right>0</right>
  </margins>
  <focus>
    <focusNew>yes</focusNew>
    <followMouse>no</followMouse>
    <raiseOnFocus>no</raiseOnFocus>
  </focus>
  <placement>
    <policy>Smart</policy>
    <center>yes</center>
  </placement>
  <theme>
    <name>FlavosOS</name>
    <titleLayout>NLIMC</titleLayout>
    <keepBorder>yes</keepBorder>
    <font place="ActiveWindow">
      <name>Inter</name>
      <size>9</size>
      <weight>Bold</weight>
    </font>
    <font place="InactiveWindow">
      <name>Inter</name>
      <size>9</size>
      <weight>Normal</weight>
    </font>
    <font place="MenuHeader">
      <name>Inter</name>
      <size>9</size>
      <weight>Bold</weight>
    </font>
    <font place="MenuItem">
      <name>Inter</name>
      <size>9</size>
      <weight>Normal</weight>
    </font>
  </theme>
  <desktops>
    <number>1</number>
    <firstdesk>1</firstdesk>
    <names><name>Desktop</name></names>
  </desktops>
  <keyboard>
    <!-- Terminal -->
    <keybind key="C-A-t">
      <action name="Execute"><command>kitty</command></action>
    </keybind>
    <!-- Menu Flavos (via xcape: Super sozinho emite Alt+F1) -->
    <keybind key="A-F1">
      <action name="Execute"><command>/usr/local/bin/flavos-shellctl launcher toggle</command></action>
    </keybind>
    <!-- Window management -->
    <keybind key="A-F4">
      <action name="Close"/>
    </keybind>
    <keybind key="A-Tab">
      <action name="NextWindow">
        <finalactions><action name="Focus"/><action name="Raise"/></finalactions>
      </action>
    </keybind>
    <keybind key="A-F11">
      <action name="ToggleFullscreen"/>
    </keybind>
    <!-- Volume (Etapa 10B) -->
    <keybind key="XF86AudioRaiseVolume">
      <action name="Execute"><command>/usr/local/bin/flavos-osd volume-up</command></action>
    </keybind>
    <keybind key="XF86AudioLowerVolume">
      <action name="Execute"><command>/usr/local/bin/flavos-osd volume-down</command></action>
    </keybind>
    <keybind key="XF86AudioMute">
      <action name="Execute"><command>/usr/local/bin/flavos-osd volume-mute</command></action>
    </keybind>
    <!-- Power Menu (Etapa 10B) -->
    <keybind key="C-A-Delete">
      <action name="Execute"><command>/usr/local/bin/flavos-power</command></action>
    </keybind>
  </keyboard>
  <mouse>
    <context name="Desktop">
      <!-- Right-click no desktop: sem ação (launcher somente via Super) -->
    </context>
    <context name="Titlebar">
      <mousebind button="Left" action="Drag">
        <action name="Move"/>
      </mousebind>
      <mousebind button="Left" action="DoubleClick">
        <action name="ToggleMaximize"/>
      </mousebind>
    </context>
    
    <context name="Iconify">
      <mousebind button="Left" action="Press">
        <action name="Iconify"/>
      </mousebind>
    </context>

    <context name="Maximize">
      <mousebind button="Left" action="Press">
        <action name="ToggleMaximize"/>
      </mousebind>
    </context>

    <context name="Close">
      <mousebind button="Left" action="Press">
        <action name="Close"/>
      </mousebind>
    </context>
    <context name="Frame">
      <mousebind button="A-Left" action="Drag">
        <action name="Move"/>
      </mousebind>
      <mousebind button="A-Right" action="Drag">
        <action name="Resize"/>
      </mousebind>
    </context>
  </mouse>
  <applications>
    <application class="*">
      <decor>yes</decor>
    </application>
  </applications>
</openbox_config>
