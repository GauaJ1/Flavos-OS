class AboutPage:
    name = "about"
    title = "Sobre"

    def build(self, win):
        scroll, vbox = _page_scroll()
        info = read_system_info()

        vbox.pack_start(_section_header("Sobre o Sistema", "Informações do ambiente Flavos OS"), False, False, 0)

        card = _card()
        card.pack_start(_row("Sistema Operacional", info["os"]), False, False, 0)
        card.pack_start(_row("Kernel Linux", info["kernel"]), False, False, 0)
        card.pack_start(_row("Arquitetura", info["arch"]), False, False, 0)
        card.pack_start(_row("Processador (CPU)", info["cpu"]), False, False, 0)
        card.pack_start(_row("Memória RAM", info["ram"]), False, False, 0)
        card.pack_start(_row("Uptime", info["uptime"]), False, False, 0)
        vbox.pack_start(card, False, False, 0)

        return scroll


class AppearancePage:
    name = "appearance"
    title = "Aparência"

    def build(self, win):
        scroll, vbox = _page_scroll()
        info = read_appearance_info()

        vbox.pack_start(_section_header("Aparência", "Wallpaper e tema de ícones"), False, False, 0)

        # Wallpaper
        card = _card()
        wrow = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        wrow.get_style_context().add_class("row-item")
        wlbl = Gtk.Label(label="Wallpaper atual", xalign=0)
        wlbl.get_style_context().add_class("row-label")
        wrow.pack_start(wlbl, True, True, 0)
        btn_pick = Gtk.Button(label="Escolher…")
        btn_pick.connect("clicked", self._pick_wallpaper, win)
        wrow.pack_end(btn_pick, False, False, 0)
        card.pack_start(wrow, False, False, 0)
        card.pack_start(_row("Caminho", info["wallpaper"]), False, False, 0)
        card.pack_start(_row("Tema de ícones", info["icon_theme"]), False, False, 0)
        vbox.pack_start(card, False, False, 0)

        # Temas de janela — placeholder
        card2 = _card()
        card2.pack_start(_row("Tema de janelas", badge=("Próxima versão", "badge-placeholder")), False, False, 0)
        card2.pack_start(_row("Cores de acento", badge=("Próxima versão", "badge-placeholder")), False, False, 0)
        vbox.pack_start(card2, False, False, 0)

        return scroll

    def _pick_wallpaper(self, btn, win):
        dialog = Gtk.FileChooserDialog(
            title="Escolher Wallpaper",
            parent=win,
            action=Gtk.FileChooserAction.OPEN
        )
        dialog.add_button("Cancelar", Gtk.ResponseType.CANCEL)
        ok_btn = dialog.add_button("Aplicar", Gtk.ResponseType.OK)
        ok_btn.get_style_context().add_class("suggested-action")
        _apply_dialog_css(dialog)

        # Pré-navegar para o wallpaper atual
        current = read_appearance_info()["wallpaper"]
        if os.path.isfile(current):
            dialog.set_filename(current)
        elif os.path.isdir(os.path.dirname(current)):
            dialog.set_current_folder(os.path.dirname(current))

        ff = Gtk.FileFilter()
        ff.set_name("Imagens")
        for p in ["*.jpg", "*.jpeg", "*.png", "*.webp"]:
            ff.add_pattern(p)
        dialog.add_filter(ff)

        resp = dialog.run()
        if resp == Gtk.ResponseType.OK:
            path = dialog.get_filename()
            _popen(["/usr/local/bin/flavos-shellctl", "wallpaper", "apply", path])

        dialog.destroy()


class NetworkPage:
    name = "network"
    title = "Rede"

    def build(self, win):
        self._win = win
        scroll, vbox = _page_scroll()
        info = read_network_info()

        nm_badge = ("● Ativo", "badge-ok") if info["nm_ok"] else ("● Inativo", "badge-warn")
        vbox.pack_start(_section_header("Rede", "Gerenciado via NetworkManager"), False, False, 0)

        # Status
        card = _card()
        card.pack_start(_row("NetworkManager", badge=nm_badge), False, False, 0)
        card.pack_start(_row("Interface ativa", info["iface"]), False, False, 0)
        card.pack_start(_row("Endereço IPv4", info["ip"]), False, False, 0)
        card.pack_start(_row("Gateway padrão", info["gateway"]), False, False, 0)
        card.pack_start(_row("DNS", info["dns"]), False, False, 0)
        vbox.pack_start(card, False, False, 0)

        # Ações
        card2 = _card()
        arow = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        arow.get_style_context().add_class("row-item")
        albl = Gtk.Label(label="Configurar conexões", xalign=0)
        albl.get_style_context().add_class("row-label")
        arow.pack_start(albl, True, True, 0)
        btn_nm = Gtk.Button(label="Abrir NM Editor")
        btn_nm.connect("clicked", lambda _: _popen(["nm-connection-editor"]))
        arow.pack_end(btn_nm, False, False, 0)
        card2.pack_start(arow, False, False, 0)

        arow2 = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        arow2.get_style_context().add_class("row-item")
        albl2 = Gtk.Label(label="Wi-Fi e outras interfaces", xalign=0)
        albl2.get_style_context().add_class("row-label")
        arow2.pack_start(albl2, True, True, 0)
        b2 = Gtk.Label(label="Próxima versão", xalign=1)
        b2.get_style_context().add_class("badge-placeholder")
        arow2.pack_end(b2, False, False, 0)
        card2.pack_start(arow2, False, False, 0)
        vbox.pack_start(card2, False, False, 0)

        return scroll


class HostnamePage:
    name = "hostname"
    title = "Hostname"

    def build(self, win):
        self._win = win
        scroll, vbox = _page_scroll()
        hostname = read_hostname()

        vbox.pack_start(_section_header("Hostname", "Nome desta máquina na rede"), False, False, 0)

        card = _card()

        # Valor atual
        card.pack_start(_row("Hostname atual", hostname), False, False, 0)

        # Linha de edição
        erow = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        erow.get_style_context().add_class("row-item")
        elbl = Gtk.Label(label="Novo hostname (letras, números, hífen — máx. 63 chars):", xalign=0)
        elbl.get_style_context().add_class("row-value")
        erow.pack_start(elbl, False, False, 0)

        hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        self._entry = Gtk.Entry()
        self._entry.set_placeholder_text("ex: meu-pc")
        self._entry.set_max_length(63)
        hbox.pack_start(self._entry, True, True, 0)

        btn = Gtk.Button(label="Aplicar")
        btn.get_style_context().add_class("action")
        btn.connect("clicked", self._apply_hostname)
        hbox.pack_end(btn, False, False, 0)
        erow.pack_start(hbox, False, False, 0)
        card.pack_start(erow, False, False, 0)
        vbox.pack_start(card, False, False, 0)

        return scroll

    def _apply_hostname(self, btn):
        new_host = self._entry.get_text().strip()
        if not re.match(r'^[a-zA-Z0-9]([a-zA-Z0-9\-]{0,61}[a-zA-Z0-9])?$', new_host):
            _show_error(
                self._win,
                "Hostname inválido",
                "Use apenas letras, números e hífen.\nNão comece nem termine com hífen."
            )
            return
        if not _show_confirm(
            self._win,
            f"Alterar hostname para \u201c{new_host}\u201d?",
            "Esta ação altera o nome da máquina na rede."
        ):
            return
        rc = _sudo_run(HELPER_HOSTNAME, new_host)
        if rc == 0:
            self._entry.set_text("")
            _show_error(
                self._win,
                f"Hostname alterado para: {new_host}",
                "Reinicie a sessão para aplicar completamente."
            )
        else:
            _show_error(
                self._win,
                "Falha ao alterar hostname",
                "Verifique se o sudo está configurado corretamente.\n"
                "Execute no terminal: sudo /usr/local/lib/flavos/helpers/flavos-set-hostname NOME"
            )


class DateTimePage:
    name = "datetime"
    title = "Data e Hora"

    def build(self, win):
        self._win = win
        scroll, vbox = _page_scroll()
        info = read_datetime_info()

        vbox.pack_start(_section_header("Data e Hora", "Fuso horário e sincronização NTP"), False, False, 0)

        # Info
        ntp_badge = ("● Ativo", "badge-ok") if info["ntp_ok"] else ("● Inativo", "badge-warn")
        card = _card()
        card.pack_start(_row("Data e Hora", info["datetime"]), False, False, 0)
        card.pack_start(_row("Fuso Horário", info["timezone"]), False, False, 0)
        card.pack_start(_row("Sincronização NTP", badge=ntp_badge), False, False, 0)
        vbox.pack_start(card, False, False, 0)

        # Ação NTP
        card2 = _card()
        nrow = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        nrow.get_style_context().add_class("row-item")
        nlbl = Gtk.Label(label="Sincronizar relógio com NTP", xalign=0)
        nlbl.get_style_context().add_class("row-label")
        nrow.pack_start(nlbl, True, True, 0)
        icon_label = "Desativar NTP" if info["ntp_ok"] else "Ativar NTP"
        btn_ntp = Gtk.Button(label=icon_label)
        if not info["ntp_ok"]:
            btn_ntp.get_style_context().add_class("action")
        btn_ntp.connect("clicked", self._toggle_ntp, info["ntp_ok"])
        nrow.pack_end(btn_ntp, False, False, 0)
        card2.pack_start(nrow, False, False, 0)

        # Placeholder: fuso horário
        card2.pack_start(_row("Alterar fuso horário", badge=("Próxima versão", "badge-placeholder")), False, False, 0)
        vbox.pack_start(card2, False, False, 0)

        return scroll

    def _toggle_ntp(self, btn, currently_active):
        action = "off" if currently_active else "on"
        verb = "desativar" if currently_active else "ativar"
        if not _show_confirm(
            self._win,
            f"{'Desativar' if currently_active else 'Ativar'} sincronização NTP?",
            f"Deseja {verb} a sincronização de horário via NTP."
        ):
            return
        rc = _sudo_run(HELPER_NTP, action)
        if rc != 0:
            _show_error(self._win, "Falha ao alterar NTP", "Verifique se o sudo está configurado.")


