#!/usr/bin/env python3
# Flavos OS — Settings App v3
# Design System v3 tokens, full CSS override, scrollable pages.

import gi
import os
import subprocess
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk, GLib

