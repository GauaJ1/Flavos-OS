#!/usr/bin/env python3
# Flavos OS - Settings App (Etapa 9C)
# Minimal, scalable, and styled via GTK3 + CSS.

import gi
import os
import subprocess
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk, GLib

CSS_DATA = b"""
window {
    background-color: #0e1015;
}
stacksidebar {
    background-color: #161922;
    border-right: 1px solid #2b2f40;
}
stacksidebar list {
    background-color: #161922;
}
stacksidebar row {
    padding: 10px;
    color: #eaecf0;
}
stacksidebar row:selected {
    background-color: #212431;
    color: #4f86f7;
    border-left: 3px solid #4f86f7;
}
stacksidebar row:hover {
    background-color: #212431;
}
label {
    color: #eaecf0;
    font-family: Inter, sans-serif;
}
label.title {
    font-size: 24px;
    font-weight: bold;
    color: #ffffff;
    margin-bottom: 24px;
}
label.subtitle {
    font-size: 16px;
    font-weight: bold;
    color: #4f86f7;
    margin-top: 16px;
    margin-bottom: 8px;
}
.card {
    background-color: #161922;
    border: 1px solid #2b2f40;
    border-radius: 4px;
    padding: 16px;
    margin-bottom: 16px;
}
button, button label {
    background-color: #212431;
    color: #eaecf0;
    border: 1px solid #2b2f40;
    border-radius: 4px;
    padding: 2px 8px;
    font-weight: bold;
}
button:hover, button:hover label {
    background-color: #2b2f40;
    color: #4f86f7;
}
button.destructive, button.destructive label {
    color: #f87171;
}
button.destructive:hover, button.destructive:hover label {
    background-color: #f87171;
    color: #ffffff;
}
entry {
    background-color: #0e1015;
    color: #eaecf0;
    border: 1px solid #2b2f40;
    padding: 8px;
    border-radius: 4px;
}
entry:disabled {
    color: #858a9d;
}
"""

def shell_run(cmd):
    try:
        return subprocess.check_output(cmd, shell=True, text=True).strip()
    except:
        return "Desconhecido"

class FlavosSettings(Gtk.ApplicationWindow):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)
        self.set_title("Flavos Settings")
        self.set_default_size(700, 500)
        
        # Injetar CSS
        css_provider = Gtk.CssProvider()
        css_provider.load_from_data(CSS_DATA)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(),
            css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        self.add(hbox)

        self.sidebar = Gtk.StackSidebar()
        self.stack = Gtk.Stack()
        self.stack.set_transition_type(Gtk.StackTransitionType.SLIDE_UP_DOWN)
        
        self.sidebar.set_stack(self.stack)
        self.sidebar.set_size_request(200, -1)
        
        hbox.pack_start(self.sidebar, False, False, 0)
        hbox.pack_start(self.stack, True, True, 0)

        self.build_about_page()
        self.build_network_page()
        self.build_user_page()
        self.build_hostname_page()
        self.build_datetime_page()
        self.build_power_page()

    def create_page_layout(self, title):
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        vbox.set_margin_top(32)
        vbox.set_margin_bottom(32)
        vbox.set_margin_start(32)
        vbox.set_margin_end(32)
        
        lbl_title = Gtk.Label(label=title, xalign=0)
        lbl_title.get_style_context().add_class("title")
        vbox.pack_start(lbl_title, False, False, 0)
        
        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        vbox.pack_start(content, False, False, 0)
        return vbox, content

    def build_about_page(self):
        page, content = self.create_page_layout("Sobre o Sistema")
        
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        card.get_style_context().add_class("card")
        
        kernel = shell_run("uname -r")
        version = shell_run("cat /etc/os-release | grep PRETTY_NAME | cut -d'\"' -f2")
        ram = shell_run("free -h | awk '/^Mem:/ {print $2}'")
        uptime = shell_run("uptime -p")

        info = [
            ("Sistema:", version if version != "Desconhecido" else "Flavos OS 0.1.0-rc1"),
            ("Kernel:", kernel),
            ("Memória RAM:", ram),
            ("Tempo de Atividade:", uptime)
        ]
        
        for k, v in info:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
            lbl_k = Gtk.Label(label=f"<b>{k}</b>", use_markup=True, xalign=0)
            lbl_k.set_size_request(150, -1)
            lbl_v = Gtk.Label(label=v, xalign=0)
            row.pack_start(lbl_k, False, False, 0)
            row.pack_start(lbl_v, True, True, 0)
            card.pack_start(row, False, False, 4)
            
        content.pack_start(card, False, False, 0)
        self.stack.add_titled(page, "about", "Sobre")

    def build_network_page(self):
        page, content = self.create_page_layout("Rede")
        
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        card.get_style_context().add_class("card")
        
        # Filtrar o IP da principal placa ethx/ensx, ignorando lo
        ip_addr = shell_run("ip -o -4 addr list | awk '!/^[0-9]*: ?lo|link\\/ether/ {print $4}' | cut -d/ -f1 | head -n 1")
        route = shell_run("ip route | grep default | awk '{print $3}'")

        info = [
            ("IPv4 Principal:", ip_addr if ip_addr else "Desconectado"),
            ("Gateway Padrão:", route if route else "N/A")
        ]
        
        for k, v in info:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
            lbl_k = Gtk.Label(label=f"<b>{k}</b>", use_markup=True, xalign=0)
            lbl_k.set_size_request(150, -1)
            lbl_v = Gtk.Label(label=v, xalign=0)
            row.pack_start(lbl_k, False, False, 0)
            row.pack_start(lbl_v, True, True, 0)
            card.pack_start(row, False, False, 4)
            
        content.pack_start(card, False, False, 0)
        
        btn_restart = Gtk.Button(label="Reiniciar Serviço de Rede")
        btn_restart.connect("clicked", lambda x: shell_run("sudo systemctl restart systemd-networkd || true"))
        content.pack_start(btn_restart, False, False, 16)
        
        lbl_info = Gtk.Label(label="Nota: Requer permissão root configurada para operar.", xalign=0)
        lbl_info.get_style_context().add_class("subtitle")
        content.pack_start(lbl_info, False, False, 0)

        self.stack.add_titled(page, "network", "Rede")

    def build_user_page(self):
        page, content = self.create_page_layout("Usuário Local")
        
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        card.get_style_context().add_class("card")
        
        user = shell_run("whoami")
        groups = shell_run("groups")
        
        row1 = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        lbl_k1 = Gtk.Label(label="<b>Usuário Logado:</b>", use_markup=True, xalign=0)
        lbl_k1.set_size_request(150, -1)
        lbl_v1 = Gtk.Label(label=user, xalign=0)
        row1.pack_start(lbl_k1, False, False, 0)
        row1.pack_start(lbl_v1, True, True, 0)
        
        row2 = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        lbl_k2 = Gtk.Label(label="<b>Grupos:</b>", use_markup=True, xalign=0)
        lbl_k2.set_size_request(150, -1)
        lbl_v2 = Gtk.Label(label=groups, xalign=0)
        lbl_v2.set_line_wrap(True)
        lbl_v2.set_max_width_chars(40)
        row2.pack_start(lbl_k2, False, False, 0)
        row2.pack_start(lbl_v2, True, True, 0)
        
        card.pack_start(row1, False, False, 4)
        card.pack_start(row2, False, False, 4)

        content.pack_start(card, False, False, 0)

        btn_pass = Gtk.Button(label="Alterar Senha (Funcionalidade Futura)")
        btn_pass.set_sensitive(False)
        content.pack_start(btn_pass, False, False, 16)

        self.stack.add_titled(page, "user", "Usuário")

    def build_hostname_page(self):
        page, content = self.create_page_layout("Identidade da Máquina")
        
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        card.get_style_context().add_class("card")
        
        hostname = shell_run("cat /etc/hostname")
        
        lbl = Gtk.Label(label="<b>Hostname atual:</b>", use_markup=True, xalign=0)
        entry = Gtk.Entry()
        entry.set_text(hostname)
        entry.set_sensitive(False) # Placeholder until polkit/sudo is structured
        
        btn = Gtk.Button(label="Aplicar Hostname")
        btn.set_sensitive(False)
        
        card.pack_start(lbl, False, False, 0)
        card.pack_start(entry, False, False, 0)
        card.pack_start(btn, False, False, 0)
        
        lbl_note = Gtk.Label(label="(Edição bloqueada. Requer elevação root na V1)", xalign=0)
        lbl_note.get_style_context().add_class("subtitle")
        
        content.pack_start(card, False, False, 0)
        content.pack_start(lbl_note, False, False, 0)
        self.stack.add_titled(page, "hostname", "Hostname")

    def build_datetime_page(self):
        page, content = self.create_page_layout("Data e Hora")
        
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        card.get_style_context().add_class("card")
        
        now = shell_run("date")
        tz = shell_run("timedatectl | grep 'Time zone' | awk '{print $3}'")
        
        info = [
            ("Hora do Host:", now),
            ("Fuso Horário:", tz if tz else "N/A")
        ]
        
        for k, v in info:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
            lbl_k = Gtk.Label(label=f"<b>{k}</b>", use_markup=True, xalign=0)
            lbl_k.set_size_request(150, -1)
            lbl_v = Gtk.Label(label=v, xalign=0)
            row.pack_start(lbl_k, False, False, 0)
            row.pack_start(lbl_v, True, True, 0)
            card.pack_start(row, False, False, 4)
            
        content.pack_start(card, False, False, 0)
        
        btn = Gtk.Button(label="Sincronizar com NTP (Funcionalidade Futura)")
        btn.set_sensitive(False)
        content.pack_start(btn, False, False, 16)
        
        self.stack.add_titled(page, "datetime", "Data e Hora")

    def build_power_page(self):
        page, content = self.create_page_layout("Energia e Sessão")
        
        lbl_warn = Gtk.Label(label="Ações de energia:", xalign=0)
        lbl_warn.get_style_context().add_class("subtitle")
        content.pack_start(lbl_warn, False, False, 0)
        
        btn_reboot = Gtk.Button(label="Reiniciar Máquina")
        btn_reboot.connect("clicked", lambda x: shell_run("sudo systemctl reboot"))
        
        btn_poweroff = Gtk.Button(label="Desligar")
        btn_poweroff.get_style_context().add_class("destructive")
        btn_poweroff.connect("clicked", lambda x: shell_run("sudo systemctl poweroff"))
        
        btn_logout = Gtk.Button(label="Encerrar Sessão Visual")
        btn_logout.connect("clicked", lambda x: shell_run("openbox --exit"))

        content.pack_start(btn_reboot, False, False, 4)
        content.pack_start(btn_poweroff, False, False, 4)
        
        sep = Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL)
        sep.set_margin_top(16)
        sep.set_margin_bottom(16)
        content.pack_start(sep, False, False, 0)
        
        content.pack_start(btn_logout, False, False, 4)
        
        self.stack.add_titled(page, "power", "Energia")

class Application(Gtk.Application):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, application_id="org.flavos.Settings", **kwargs)
        self.window = None

    def do_activate(self):
        if not self.window:
            self.window = FlavosSettings(application=self, title="Flavos Settings")
        self.window.show_all()
        self.window.present()

if __name__ == "__main__":
    app = Application()
    app.run(None)
