def shell_run(cmd):
    try:
        return subprocess.check_output(cmd, shell=True, text=True).strip()
    except Exception:
        return "Desconhecido"

class FlavosSettings(Gtk.ApplicationWindow):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)
        self.set_title("Flavos Settings")
        self.set_default_size(720, 520)

        css_provider = Gtk.CssProvider()
        css_provider.load_from_data(CSS_DATA)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(),
            css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_USER
        )

        hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        self.add(hbox)

        self.sidebar = Gtk.StackSidebar()
        self.stack = Gtk.Stack()
        self.stack.set_transition_type(Gtk.StackTransitionType.CROSSFADE)
        self.stack.set_transition_duration(150)

        self.sidebar.set_stack(self.stack)
        self.sidebar.set_size_request(200, -1)

        hbox.pack_start(self.sidebar, False, False, 0)
        hbox.pack_start(self.stack, True, True, 0)

        self.build_about_page()
        self.build_network_page()
        self.build_user_page()
        self.build_hostname_page()
        self.build_datetime_page()
        self.build_power_page()

    def create_page_layout(self, title):
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)

        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        vbox.set_margin_top(32)
        vbox.set_margin_bottom(32)
        vbox.set_margin_start(32)
        vbox.set_margin_end(32)

        lbl_title = Gtk.Label(label=title, xalign=0)
        lbl_title.get_style_context().add_class("title")
        vbox.pack_start(lbl_title, False, False, 0)

        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        vbox.pack_start(content, False, False, 0)

        scroll.add(vbox)
        return scroll, content

    def _info_card(self, content, info_pairs):
        """Reusable card with key-value rows."""
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        card.get_style_context().add_class("card")

        for k, v in info_pairs:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
            lbl_k = Gtk.Label(label=f"<b>{k}</b>", use_markup=True, xalign=0)
            lbl_k.set_size_request(160, -1)
            lbl_v = Gtk.Label(label=v, xalign=0)
            lbl_v.set_line_wrap(True)
            lbl_v.set_max_width_chars(50)
            row.pack_start(lbl_k, False, False, 0)
            row.pack_start(lbl_v, True, True, 0)
            card.pack_start(row, False, False, 6)

        content.pack_start(card, False, False, 0)
        return card

    def build_about_page(self):
        page, content = self.create_page_layout("Sobre o Sistema")

        kernel = shell_run("uname -r")
        version = shell_run("cat /etc/os-release | grep PRETTY_NAME | cut -d'\"' -f2")
        ram = shell_run("free -h | awk '/^Mem:/ {print $2}'")
        uptime = shell_run("uptime -p")

        self._info_card(content, [
            ("Sistema:", version if version != "Desconhecido" else "Flavos OS 0.1.0-rc1"),
            ("Kernel:", kernel),
            ("Memória RAM:", ram),
            ("Uptime:", uptime),
        ])

        self.stack.add_titled(page, "about", "Sobre")

    def build_network_page(self):
        page, content = self.create_page_layout("Rede")

        ip_addr = shell_run(
            "ip -o -4 addr list | awk '!/^[0-9]*: ?lo|link\\/ether/ {print $4}' | cut -d/ -f1 | head -n 1"
        )
        route = shell_run("ip route | grep default | awk '{print $3}'")

        self._info_card(content, [
            ("IPv4:", ip_addr if ip_addr else "Desconectado"),
            ("Gateway:", route if route else "N/A"),
        ])

        btn = Gtk.Button(label="Reiniciar Rede")
        btn.connect("clicked", lambda x: shell_run("sudo systemctl restart systemd-networkd || true"))
        content.pack_start(btn, False, False, 16)

        lbl = Gtk.Label(label="Requer credenciais de administrador.", xalign=0)
        lbl.get_style_context().add_class("subtitle")
        content.pack_start(lbl, False, False, 0)

        self.stack.add_titled(page, "network", "Rede")

    def build_user_page(self):
        page, content = self.create_page_layout("Conta de Usuário")

        user = shell_run("whoami")
        groups = shell_run("groups")

        self._info_card(content, [
            ("Usuário:", user),
            ("Grupos:", groups),
        ])

        btn = Gtk.Button(label="Alterar Senha")
        btn.set_sensitive(False)
        content.pack_start(btn, False, False, 16)

        lbl = Gtk.Label(label="Funcionalidade disponível em versão futura.", xalign=0)
        lbl.get_style_context().add_class("subtitle")
        content.pack_start(lbl, False, False, 0)

        self.stack.add_titled(page, "user", "Usuário")

    def build_hostname_page(self):
        page, content = self.create_page_layout("Identidade da Máquina")

        hostname = shell_run("cat /etc/hostname")

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        card.get_style_context().add_class("card")

        lbl = Gtk.Label(label="<b>Hostname:</b>", use_markup=True, xalign=0)
        entry = Gtk.Entry()
        entry.set_text(hostname)
        entry.set_sensitive(False)

        btn = Gtk.Button(label="Aplicar")
        btn.set_sensitive(False)

        card.pack_start(lbl, False, False, 0)
        card.pack_start(entry, False, False, 4)
        card.pack_start(btn, False, False, 4)

        content.pack_start(card, False, False, 0)

        lbl_note = Gtk.Label(label="Edição disponível em versão futura.", xalign=0)
        lbl_note.get_style_context().add_class("subtitle")
        content.pack_start(lbl_note, False, False, 8)

        self.stack.add_titled(page, "hostname", "Hostname")

    def build_datetime_page(self):
        page, content = self.create_page_layout("Data e Hora")

        now = shell_run("date")
        tz = shell_run("timedatectl | grep 'Time zone' | awk '{print $3}'")

        self._info_card(content, [
            ("Hora:", now),
            ("Fuso:", tz if tz else "N/A"),
        ])

        btn = Gtk.Button(label="Sincronizar com NTP")
        btn.set_sensitive(False)
        content.pack_start(btn, False, False, 16)

        lbl = Gtk.Label(label="Funcionalidade disponível em versão futura.", xalign=0)
        lbl.get_style_context().add_class("subtitle")
        content.pack_start(lbl, False, False, 0)

        self.stack.add_titled(page, "datetime", "Data e Hora")

    def build_power_page(self):
        page, content = self.create_page_layout("Energia e Sessão")

        lbl = Gtk.Label(label="Gerenciado pela shell do sistema:", xalign=0)
        lbl.get_style_context().add_class("subtitle")
        content.pack_start(lbl, False, False, 0)

        btn = Gtk.Button(label="Abrir Menu de Energia")
        btn.connect("clicked", lambda x: subprocess.Popen(["/usr/local/bin/flavos-power"]))
        content.pack_start(btn, False, False, 12)

        self.stack.add_titled(page, "power", "Energia")


class Application(Gtk.Application):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, application_id="org.flavos.Settings", **kwargs)
        self.window = None

    def do_activate(self):
        if not self.window:
            self.window = FlavosSettings(application=self, title="Flavos Settings")
        self.window.show_all()
        self.window.present()


if __name__ == "__main__":
    app = Application()
    app.run(None)
