/* === Flavos OS Settings — CSS v3 === */
/* canvas=#0D1017 surface=#151921 elevated=#1C2030
   overlay=#232838 accent=#4B8BF5 border=#272D3D
   fg.primary=#E8ECF4 fg.secondary=#8891A5 fg.muted=#505872 */

/* --- Reset & Base --- */
* {
    -GtkWidget-focus-padding: 0;
    -GtkWidget-focus-line-width: 0;
    outline-style: none;
    outline-width: 0;
    transition: background-color 150ms ease-in-out,
                color 150ms ease-in-out,
                border-color 150ms ease-in-out;
}

window, .background {
    background-color: #0D1017;
