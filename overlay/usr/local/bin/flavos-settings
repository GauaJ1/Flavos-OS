#!/usr/bin/env python3
# Flavos OS — Settings App v3
# Design System v3 tokens. CSS simplificado (GTK3-compatible).

import gi
import subprocess
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk

# CSS limpo e compatível com GTK3 — sem propriedades inválidas
