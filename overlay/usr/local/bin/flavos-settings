# ---------------------------------------------------------------------------
# Backend: leitura de estado (sem privilégio)
# ---------------------------------------------------------------------------
def _shell(cmd, shell=False):
    """Executa comando e retorna stdout. Nunca levanta exceção."""
    try:
        result = subprocess.check_output(
            cmd, shell=shell, text=True,
            stderr=subprocess.DEVNULL, timeout=4
        )
        return result.strip()
    except Exception:
        return ""


def _popen(argv):
    """Lança processo em background. Retorna Popen."""
    return subprocess.Popen(argv, stderr=subprocess.DEVNULL)


def _sudo_run(helper, *args):
    """Executa helper privilegiado via sudo (NOPASSWD configurado em sudoers.d).
    Retorna returncode. pkexec não suporta scripts shell em Debian por política de seguraça.
    """
    cmd = ["sudo", helper] + list(args)
    try:
        proc = subprocess.run(cmd, timeout=30, capture_output=True)
        return proc.returncode
    except Exception:
        return -1


HELPER_HOSTNAME = "/usr/local/lib/flavos/helpers/flavos-set-hostname"
HELPER_NTP = "/usr/local/lib/flavos/helpers/flavos-set-ntp"


def read_system_info():
    return {
        "os":     _shell(["bash", "-c", "grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d'\"' -f2"]) or "Flavos OS",
        "kernel": _shell(["uname", "-r"]),
        "arch":   _shell(["uname", "-m"]),
        "ram":    _shell(["bash", "-c", "free -h | awk '/^Mem:/ {print $2 \" total, \" $3 \" usado\"}'"] ),
        "cpu":    _shell(["bash", "-c", "grep -m1 'model name' /proc/cpuinfo | cut -d: -f2"]).strip() or "Desconhecido",
        "uptime": _shell(["uptime", "-p"]),
        "host":   _shell(["hostname"]) or "flavos",
    }


def read_network_info():
    ip = _shell(["bash", "-c", "ip -o -4 addr show | awk '!/lo/{print $4}' | cut -d/ -f1 | head -1"])
    gw = _shell(["bash", "-c", "ip route show default | awk '{print $3}' | head -1"])
    iface = _shell(["bash", "-c", "ip route show default | awk '{print $5}' | head -1"])
    nm_active = _shell(["bash", "-c", "systemctl is-active NetworkManager 2>/dev/null"])
    dns = _shell(["bash", "-c", "resolvectl status 2>/dev/null | grep 'DNS Servers' | head -1 | cut -d: -f2"]).strip()
    return {
        "ip":       ip or "Desconectado",
        "gateway":  gw or "—",
        "iface":    iface or "—",
        "dns":      dns or "—",
        "nm_ok":    nm_active == "active",
    }


def read_datetime_info():
    now = _shell(["date", "+%d/%m/%Y %H:%M:%S"])
    tz = _shell(["bash", "-c", "timedatectl 2>/dev/null | awk '/Time zone:/{print $3}'"])
    ntp = _shell(["bash", "-c", "timedatectl 2>/dev/null | awk '/NTP service:/{print $3}'"])
    ntp_ok = "active" in ntp.lower() or "yes" in ntp.lower()
    return {
        "datetime": now,
        "timezone": tz or "Desconhecido",
        "ntp_ok":   ntp_ok,
    }


def read_hostname():
    return _shell(["hostname"]) or "flavos"


def read_user_info():
    user = _shell(["whoami"])
    uid = _shell(["id", "-u"])
    groups = _shell(["groups"])
    shell = os.environ.get("SHELL", _shell(["bash", "-c", "getent passwd $(whoami) | cut -d: -f7"]))
    return {"user": user, "uid": uid, "groups": groups, "shell": shell}


def read_appearance_info():
    wallpaper_cfg = os.path.expanduser("~/.config/flavos/wallpaper")
    if os.path.isfile(wallpaper_cfg):
        with open(wallpaper_cfg) as f:
            wallpaper = f.read().strip()
    else:
        wallpaper = "/usr/share/flavos/wallpaper.jpeg"
    icon_theme = _shell(["bash", "-c", "grep gtk-icon-theme-name ~/.gtkrc-2.0 2>/dev/null | cut -d'\"' -f2"])
    return {"wallpaper": wallpaper, "icon_theme": icon_theme or "Papirus-Dark"}


def read_power_info():
    governor = _shell(["bash", "-c", "cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null"])
    acpi = _shell(["bash", "-c", "acpi -b 2>/dev/null | head -1"])
    has_battery = bool(acpi)
    return {
        "governor": governor or "Indisponível",
        "acpi":     acpi or "Sem bateria detectada",
        "has_battery": has_battery,
    }


# ---------------------------------------------------------------------------
# Componentes de UI reutilizáveis
# ---------------------------------------------------------------------------
def _card():
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
    box.get_style_context().add_class("card")
    return box


def _row(label_text, value_text="", badge=None):
    """Linha de informação: label à esquerda, valor/badge à direita."""
    row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
    row.get_style_context().add_class("row-item")

    lbl = Gtk.Label(label=label_text, xalign=0)
    lbl.get_style_context().add_class("row-label")
    row.pack_start(lbl, True, True, 0)

    if badge:
        b = Gtk.Label(label=badge[0])
        b.get_style_context().add_class(badge[1])
        row.pack_end(b, False, False, 0)
    elif value_text:
        val = Gtk.Label(label=value_text, xalign=1)
        val.get_style_context().add_class("row-value")
        val.set_max_width_chars(30)
        val.set_line_wrap(True)
        row.pack_end(val, False, False, 0)

    return row


def _section_header(title, subtitle=""):
    box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
    box.set_margin_bottom(8)
    t = Gtk.Label(label=title, xalign=0)
    t.get_style_context().add_class("section-title")
    box.pack_start(t, False, False, 0)
    if subtitle:
        s = Gtk.Label(label=subtitle, xalign=0)
        s.get_style_context().add_class("section-subtitle")
        box.pack_start(s, False, False, 0)
    return box


def _page_scroll():
    scroll = Gtk.ScrolledWindow()
    scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
    vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
    vbox.set_margin_top(32)
    vbox.set_margin_bottom(32)
    vbox.set_margin_start(32)
    vbox.set_margin_end(32)
    scroll.add(vbox)
    return scroll, vbox


# ---------------------------------------------------------------------------
# FlavosDialog: Dialog modal customizado sem decoracoes do WM
# Resolve o problema do Openbox desenhar titlebar bruta nos Gtk.MessageDialog
# ---------------------------------------------------------------------------
_CSS_FLAVOS_DIALOG = b"""
.flavos-dialog-overlay {
    background-color: alpha(#000000, 0.5);
}
.flavos-dialog-surface {
    background-color: #131825;
    border: 1px solid #2A3450;
    border-radius: 12px;
    padding: 28px;
}
.flavos-dialog-title {
    font-size: 15px;
    font-weight: 700;
    color: #E8ECF4;
    margin-bottom: 10px;
}
.flavos-dialog-body {
    font-size: 13px;
    color: #8891A5;
    margin-bottom: 24px;
}
.flavos-dialog-btn {
    background-image: none;
    background-color: #1C2436;
    color: #A8B0C8;
    border: 1px solid #2A3450;
    border-radius: 8px;
    padding: 9px 20px;
    box-shadow: none;
    min-width: 80px;
}
.flavos-dialog-btn label {
    color: #A8B0C8;
}
.flavos-dialog-btn:hover {
    background-image: none;
    background-color: #232D47;
}
.flavos-dialog-btn:hover label {
    color: #E8ECF4;
}
.flavos-dialog-btn-primary {
    background-image: none;
    background-color: #4B8BF5;
    border-color: #4B8BF5;
    border-radius: 8px;
    padding: 9px 20px;
    box-shadow: none;
    min-width: 80px;
}
.flavos-dialog-btn-primary label {
    color: #FFFFFF;
    font-weight: 700;
}
.flavos-dialog-btn-primary:hover {
    background-image: none;
    background-color: #3A7AE4;
}
"""


class FlavosDialog(Gtk.Window):
    """Janela modal customizada sem decoracoes WM.
    O Openbox nao toca nela: nao ha titlebar gerada pelo WM.
    Suporta modo 'confirm' (Cancel + OK) e 'error' (OK).
    Retorna True se o usuario clicou OK.
    """
    RESULT_OK = True
    RESULT_CANCEL = False

    def __init__(self, parent, title, message, mode="error"):
        super().__init__(type=Gtk.WindowType.POPUP)
        self.set_decorated(False)
        self.set_modal(True)
        self.set_transient_for(parent)
        self.set_position(Gtk.WindowPosition.CENTER_ON_PARENT)
        self.set_resizable(False)
        self.set_keep_above(True)
        self._result = False

        # Injetar CSS de dialog
        p = Gtk.CssProvider()
        p.load_from_data(_CSS_FLAVOS_DIALOG)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), p, Gtk.STYLE_PROVIDER_PRIORITY_USER
        )

        # Surface
        surface = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        surface.get_style_context().add_class("flavos-dialog-surface")
        surface.set_size_request(360, -1)
        self.add(surface)

        # Titulo
        lbl_title = Gtk.Label(label=title, xalign=0)
        lbl_title.get_style_context().add_class("flavos-dialog-title")
        lbl_title.set_line_wrap(True)
        lbl_title.set_max_width_chars(40)
        surface.pack_start(lbl_title, False, False, 0)

        # Mensagem
        lbl_msg = Gtk.Label(label=message, xalign=0)
        lbl_msg.get_style_context().add_class("flavos-dialog-body")
        lbl_msg.set_line_wrap(True)
        lbl_msg.set_max_width_chars(40)
        surface.pack_start(lbl_msg, False, False, 0)

        # Botoes
        btn_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        btn_row.set_halign(Gtk.Align.END)
        surface.pack_start(btn_row, False, False, 0)

        if mode == "confirm":
            btn_cancel = Gtk.Button(label="Cancelar")
            btn_cancel.get_style_context().add_class("flavos-dialog-btn")
            btn_cancel.connect("clicked", self._on_cancel)
            btn_row.pack_start(btn_cancel, False, False, 0)

        btn_ok = Gtk.Button(label="OK" if mode == "error" else "Confirmar")
        btn_ok.get_style_context().add_class("flavos-dialog-btn-primary")
        btn_ok.connect("clicked", self._on_ok)
        btn_row.pack_start(btn_ok, False, False, 0)

        self.connect("key-press-event", self._on_key)
        self.show_all()

    def _on_ok(self, _):
        self._result = True
        self.destroy()
        Gtk.main_quit()

    def _on_cancel(self, _):
        self._result = False
        self.destroy()
        Gtk.main_quit()

    def _on_key(self, widget, event):
        if event.keyval == Gdk.KEY_Return:
            self._on_ok(None)
        elif event.keyval == Gdk.KEY_Escape:
            self._on_cancel(None)
        return False

    def run(self):
        Gtk.main()
        return self._result


def _show_error(parent, title, msg=""):
    """Mostra dialog de erro com FlavosDialog."""
    d = FlavosDialog(parent, title, msg, mode="error")
    d.run()


def _show_confirm(parent, title, msg=""):
    """Mostra dialog de confirmacao. Retorna True se o usuario confirmou."""
    d = FlavosDialog(parent, title, msg, mode="confirm")
    return d.run()


