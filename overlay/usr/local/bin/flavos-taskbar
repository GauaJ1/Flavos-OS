#!/usr/bin/env python3
# Flavos Native Taskbar v4 (Etapa 11B — Redesign Premium)
# Dock híbrida: ícone de menu + apps fixados + Wnck.Tasklist + systray right
#
# Decisão arquitetural:
#   - Relógio fica na direita da taskbar INFERIOR (pedido do usuário)
#   - Ícones de sistema (volume, rede, notificações) ficam na direita
#   - Branding textual "FLAVOS" fica somente no painel superior
#   - Botão de Menu usa ícone, aciona flavos-shellctl launcher toggle

import gi
import os
import sys
import json
import subprocess
from datetime import datetime

# Guard: X11 only nesta fase
if os.environ.get("XDG_SESSION_TYPE", "x11") != "x11":
    print("[flavos-taskbar] Ignorado: sessão não-X11.")
    sys.exit(0)

gi.require_version('Gtk', '3.0')
gi.require_version('Wnck', '3.0')
from gi.repository import Gtk, Gdk, Wnck, GLib

# Obrigatório: anunciar como PAGER antes de qualquer uso do Wnck
Wnck.set_client_type(Wnck.ClientType.PAGER)

# ── Config ────────────────────────────────────────────────────────────────────
CONFIG_PATH = os.path.expanduser("~/.config/flavos/panel.json")

# Apps fixados — estrutura organizada: (icon_name, command_argv, tooltip)
PINNED_APPS = [
    ("utilities-terminal",      ["kitty"],      "Terminal"),
    ("system-file-manager",     ["pcmanfm"],    "Arquivos"),
    ("accessories-text-editor", ["mousepad"],   "Editor"),
]

def load_config():
    if os.path.exists(CONFIG_PATH):
        try:
            with open(CONFIG_PATH, "r") as f:
                return json.load(f)
        except Exception:
            pass
    return {"opacity": 100, "alignment": "left", "style": "solid"}


# ── CSS — System CSS Architecture Skill ───────────────────────────────────────
# Tokens:
#   Surface base:       #0D1017
#   Surface raised:     #131720
#   Surface raised+1:   #1A1F2B
#   Border subtle:      rgba(255,255,255,0.06)
#   Text muted:         #6B7385
#   Text secondary:     #8891A5
#   Text primary:       #E8ECF4
#   Accent:             #4B8BF5
#   Radius sm:          6px
#   Radius md:          8px
#   Radius lg:          12px
# Motion tokens (state feedback): 100ms cubic-bezier(0.2, 0, 0, 1)
# Motion tokens (hover emphasis): 150ms ease

BASE_CSS_SOLID = """
/* ── Taskbar Surface ──────────────────────────────────────────────────── */
#FlavosTaskbar {
    background-color: #0D1017;
    border-top: 1px solid rgba(255,255,255,0.06);
}

/* ── Botão de Menu (ícone do sistema) ──────────────────────────────────── */
button.menu-btn {
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 8px;
    min-width: 40px;
    min-height: 32px;
    padding: 0 10px;
    margin: 4px 2px 4px 6px;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1);
}
button.menu-btn:hover {
    background-image: none;
    background-color: rgba(255,255,255,0.07);
}
button.menu-btn:active {
    background-image: none;
    background-color: rgba(75, 139, 245, 0.3);
}

/* ── Apps Fixados ──────────────────────────────────────────────────────── */
button.pinned-btn {
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 8px;
    min-width: 36px;
    min-height: 32px;
    padding: 0 8px;
    margin: 4px 1px;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1);
}
