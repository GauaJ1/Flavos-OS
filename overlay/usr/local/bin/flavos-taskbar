#!/usr/bin/env python3
# Flavos Native Taskbar v4 (Correção Final)
# Dock moderna: menu icon + pinned apps + Wnck.Tasklist + status icons + relógio.
# Gerenciada pelo flavos-session-daemon.
#
# Decisões arquiteturais:
#   - Branding "FLAVOS" fica SOMENTE no painel superior (Gtk.Label)
#   - Relógio inferior: compacto (HH:MM), discreto, não compete com o topo
#   - Status icons (rede, volume) são wrappers funcionais que abrem ferramentas nativas
#   - Ícone de notificação é placeholder controlado (dunst não expõe API GTK nativa)
#   - max-width nos botões Wnck: hipótese aplicada via CSS, validável em teste

import gi
import os
import sys
import json
import subprocess
from datetime import datetime

# Guard: X11 only nesta fase
if os.environ.get("XDG_SESSION_TYPE", "x11") != "x11":
    print("[flavos-taskbar] Ignorado: sessão não-X11.")
    sys.exit(0)

gi.require_version('Gtk', '3.0')
gi.require_version('Wnck', '3.0')
from gi.repository import Gtk, Gdk, Wnck, GLib

# Obrigatório: anunciar como PAGER antes de qualquer uso do Wnck
Wnck.set_client_type(Wnck.ClientType.PAGER)

# ── Config ────────────────────────────────────────────────────────────────────
CONFIG_PATH = os.path.expanduser("~/.config/flavos/panel.json")

# Apps fixados — estrutura organizada, extensível via config futura.
# Cada entrada: (icon_name, command_argv, tooltip)
PINNED_APPS = [
    ("utilities-terminal",      ["kitty"],    "Terminal"),
    ("system-file-manager",     ["pcmanfm"],  "Arquivos"),
    ("accessories-text-editor", ["mousepad"], "Editor"),
]

def load_config():
    if os.path.exists(CONFIG_PATH):
        try:
            with open(CONFIG_PATH, "r") as f:
                return json.load(f)
        except Exception:
            pass
    return {"opacity": 100, "alignment": "left", "style": "solid"}


# ── CSS ───────────────────────────────────────────────────────────────────────
# Motion tokens (system-motion-design skill):
#   - State feedback: 100ms, cubic-bezier(0.2, 0, 0, 1)
#   - Hover emphasis: 120ms ease
# Tokens visuais equalizados com flavos-panel:
#   - Surface: #0D1017    Border: #272D3D
#   - Text muted: #8891A5  Text active: #E8ECF4
#   - Accent: #4B8BF5     Hover surface: #1A1F2B
#
# Nota sobre max-width nos botões Wnck.Tasklist:
# Hipótese validável — GTK3 pode ou não respeitar max-width em botões Wnck
# nativos. Aplicado como CSS; se não funcionar, o Wnck.Tasklist já faz
# truncamento natural por pressão de espaço. Sem risco de regressão.

BASE_CSS_SOLID = """
#FlavosTaskbar {
    background-color: #0D1017;
    border-top: 1px solid #272D3D;
}

/* Menu button (ícone start) */
window#FlavosTaskbar button.menu-btn {
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 4px 10px;
    margin: 4px 2px 4px 6px;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1);
}
window#FlavosTaskbar button.menu-btn:hover {
    background-image: none;
    background-color: #1A1F2B;
}
window#FlavosTaskbar button.menu-btn:active {
    background-image: none;
    background-color: #4B8BF5;
}

/* Apps fixados */
window#FlavosTaskbar button.pinned-btn {
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 4px 6px;
    margin: 4px 1px;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1);
}
window#FlavosTaskbar button.pinned-btn:hover {
    background-image: none;
    background-color: #1A1F2B;
}
window#FlavosTaskbar button.pinned-btn:active {
    background-image: none;
    background-color: rgba(75, 139, 245, 0.25);
}

/* Separadores */
separator.task-sep {
    background-color: #272D3D;
    min-width: 1px;
    margin: 8px 4px;
}

/* Wnck.Tasklist — janelas abertas */
window#FlavosTaskbar WnckTasklist {
    background-color: transparent;
    background-image: none;
}

window#FlavosTaskbar WnckTasklist button {
    background-image: none;
    background-color: transparent;
    border: none;
    border-top: none;
    border-left: none;
    border-right: none;
    border-radius: 6px;
    padding: 2px 8px;
    margin: 4px 1px;
    color: #8891A5;
    font-family: Inter, sans-serif;
    font-size: 11px;
    font-weight: 500;
    border-bottom: 2px solid transparent;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1),
                color 100ms cubic-bezier(0.2, 0, 0, 1),
                border-bottom-color 120ms ease;
}

window#FlavosTaskbar WnckTasklist button:hover {
    background-image: none;
    background-color: #1A1F2B;
    color: #C8CDD8;
}

window#FlavosTaskbar WnckTasklist button:focus-visible {
    background-image: none;
    outline: 2px solid #4B8BF5;
    outline-offset: 2px;
}

window#FlavosTaskbar WnckTasklist button:checked {
    background-image: none;
    background-color: #1E2433;
    color: #E8ECF4;
    border-bottom: 2px solid #4B8BF5;
}

/* Status icons (direita) */
window#FlavosTaskbar button.status-btn {
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 4px 6px;
    margin: 4px 1px;
    color: #8891A5;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1),
                color 100ms cubic-bezier(0.2, 0, 0, 1);
}
window#FlavosTaskbar button.status-btn:hover {
    background-image: none;
    background-color: #1A1F2B;
    color: #E8ECF4;
}

/* Relógio compacto (não compete com o informacional do topo) */
label.taskbar-clock {
    font-family: Inter, sans-serif;
    font-size: 11px;
    font-weight: 500;
    color: #8891A5;
    padding: 0 10px 0 4px;
}
"""

BASE_CSS_GLASS = """
#FlavosTaskbar {{
    background-color: rgba(13, 16, 23, {alpha});
    border-top: 1px solid rgba(39, 45, 61, {alpha});
}}

window#FlavosTaskbar button.menu-btn {{
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 4px 10px;
    margin: 4px 2px 4px 6px;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1);
}}
window#FlavosTaskbar button.menu-btn:hover {{
    background-image: none;
    background-color: rgba(26, 31, 43, {hover_alpha});
}}
window#FlavosTaskbar button.menu-btn:active {{
    background-image: none;
    background-color: #4B8BF5;
}}

window#FlavosTaskbar button.pinned-btn {{
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 4px 6px;
    margin: 4px 1px;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1);
}}
window#FlavosTaskbar button.pinned-btn:hover {{
    background-image: none;
    background-color: rgba(26, 31, 43, {hover_alpha});
}}
window#FlavosTaskbar button.pinned-btn:active {{
    background-image: none;
    background-color: rgba(75, 139, 245, 0.25);
}}

separator.task-sep {{
    background-color: rgba(39, 45, 61, {alpha});
    min-width: 1px;
    margin: 8px 4px;
}}

window#FlavosTaskbar WnckTasklist {{
    background-color: transparent;
    background-image: none;
}}

window#FlavosTaskbar WnckTasklist button {{
    background-image: none;
    background-color: transparent;
    border: none;
    border-top: none;
    border-left: none;
    border-right: none;
    border-radius: 6px;
    padding: 2px 8px;
    margin: 4px 1px;
    color: #8891A5;
    font-family: Inter, sans-serif;
    font-size: 11px;
    font-weight: 500;
    border-bottom: 2px solid transparent;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1),
                color 100ms cubic-bezier(0.2, 0, 0, 1),
                border-bottom-color 120ms ease;
}}

window#FlavosTaskbar WnckTasklist button:hover {{
    background-image: none;
    background-color: rgba(26, 31, 43, {hover_alpha});
    color: #C8CDD8;
}}

window#FlavosTaskbar WnckTasklist button:focus-visible {{
    background-image: none;
    outline: 2px solid #4B8BF5;
    outline-offset: 2px;
}}

window#FlavosTaskbar WnckTasklist button:checked {{
    background-image: none;
    background-color: #1E2433;
    color: #E8ECF4;
    border-bottom: 2px solid #4B8BF5;
}}

window#FlavosTaskbar button.status-btn {{
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 4px 6px;
    margin: 4px 1px;
    color: #8891A5;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1),
                color 100ms cubic-bezier(0.2, 0, 0, 1);
}}
window#FlavosTaskbar button.status-btn:hover {{
    background-image: none;
    background-color: rgba(26, 31, 43, {hover_alpha});
    color: #E8ECF4;
}}

label.taskbar-clock {{
    font-family: Inter, sans-serif;
    font-size: 11px;
    font-weight: 500;
    color: #8891A5;
    padding: 0 10px 0 4px;
}}
"""


def spawn_app(argv):
    """Lança app em background, desacoplado do ciclo Gtk."""
    subprocess.Popen(argv, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


class FlavosTaskbar(Gtk.Window):
    def __init__(self):
        super().__init__(type=Gtk.WindowType.TOPLEVEL)
        self.set_name("FlavosTaskbar")
        self.set_title("Flavos Taskbar")
        self.set_decorated(False)
        self.set_resizable(False)
        self.set_accept_focus(False)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)
        self.set_type_hint(Gdk.WindowTypeHint.DOCK)

        # ── Config e CSS ──────────────────────────────────────────────────
        cfg = load_config()
        style = cfg.get("style", "solid")
        opacity = cfg.get("opacity", 100)

        if style == "glass":
            self.set_app_paintable(True)
            screen = self.get_screen()
            visual = screen.get_rgba_visual()
            if visual and screen.is_composited():
                self.set_visual(visual)

        if style == "glass":
            alpha_val = float(opacity) / 100.0
            hover_alpha_val = min(1.0, alpha_val + 0.25)
            css_str = BASE_CSS_GLASS.format(alpha=alpha_val, hover_alpha=hover_alpha_val)
        else:
            css_str = BASE_CSS_SOLID

        provider = Gtk.CssProvider()
        provider.load_from_data(css_str.encode("utf-8"))
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_USER
        )

        # ── Geometria ─────────────────────────────────────────────────────
        display = Gdk.Display.get_default()
        monitor = display.get_primary_monitor() or display.get_monitor(0)
        geom = monitor.get_geometry()
        self.set_default_size(geom.width, 36)
        self.move(geom.x, geom.y + geom.height - 36)

        # ── Wnck Screen ──────────────────────────────────────────────────
        self._screen = Wnck.Screen.get_default()
        if not self._screen:
            print("[flavos-taskbar] CRITICAL: Wnck.Screen indisponível.", file=sys.stderr)
            sys.exit(1)

        # ── Layout ────────────────────────────────────────────────────────
        # [ Menu ] [ Pin ] [ Pin ] [ Pin ] │ [ Wnck.Tasklist ] │ [ 🔊 ] [ 📶 ] [ 🔔 ] [ 14:22 ]
        main_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        self.add(main_box)

        # ── Esquerda: Menu + Pinned Apps ──────────────────────────────────
        # 1. Botão de menu (ícone, abre launcher via shellctl)
        btn_menu = Gtk.Button()
        btn_menu.get_style_context().add_class("menu-btn")
        menu_icon = Gtk.Image.new_from_icon_name("start-here-symbolic", Gtk.IconSize.BUTTON)
        btn_menu.add(menu_icon)
        btn_menu.set_tooltip_text("Menu (Super)")
        btn_menu.connect("clicked", lambda _: spawn_app(
            ["/usr/local/bin/flavos-shellctl", "launcher", "toggle"]
        ))
        main_box.pack_start(btn_menu, False, False, 0)

        # 2. Apps fixados (da lista PINNED_APPS)
        for icon_name, cmd, tooltip in PINNED_APPS:
            btn = Gtk.Button()
            btn.get_style_context().add_class("pinned-btn")
            img = Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.BUTTON)
            btn.add(img)
            btn.set_tooltip_text(tooltip)
            btn.connect("clicked", lambda _, c=cmd: spawn_app(c))
            main_box.pack_start(btn, False, False, 0)

        # 3. Separador esquerdo
        sep_left = Gtk.Separator(orientation=Gtk.Orientation.VERTICAL)
        sep_left.get_style_context().add_class("task-sep")
        main_box.pack_start(sep_left, False, False, 0)

        # ── Centro: Wnck.Tasklist (núcleo funcional) ─────────────────────
        tasklist = Wnck.Tasklist.new()
        tasklist.set_grouping(Wnck.TasklistGroupingType.AUTO_GROUP)
        tasklist.set_switch_workspace_on_unminimize(True)
        tasklist.set_include_all_workspaces(True)
        tasklist.set_button_relief(Gtk.ReliefStyle.NONE)
        # O pulo do gato: h-align START faz com que a tasklist não estique 
        # seus botões infinitamente para preencher o espaço vazio do painel.
        # Ela apenas ocupará o espaço necessário pelos botões.
        tasklist.set_halign(Gtk.Align.START)
        main_box.pack_start(tasklist, True, True, 0)

        # ── Direita: Status Icons + Relógio ───────────────────────────────
        # NOTA: pack_end adiciona da borda DIREITA para a ESQUERDA.
        # Primeira chamada = mais à direita. Última chamada = mais à esquerda.
        # Ordem visual desejada (esq→dir): [sep] [vol] [net] [notif] [clock]

        # Relógio compacto
        self.lbl_clock = Gtk.Label()
        self.lbl_clock.set_justify(Gtk.Justification.CENTER)
        self.lbl_clock.get_style_context().add_class("taskbar-clock")
        main_box.pack_end(self.lbl_clock, False, False, 0)

        # Ícone de notificações — PLACEHOLDER CONTROLADO
        # O dunst (serviço de notificações) não expõe API GTK nativa.
        # Este botão é um placeholder visual que abre a última notificação
        # via dunstctl. Será substituído por integração real quando disponível.
        btn_notif = Gtk.Button()
        btn_notif.get_style_context().add_class("status-btn")
        btn_notif.add(Gtk.Image.new_from_icon_name(
            "notification-symbolic", Gtk.IconSize.MENU
        ))
        btn_notif.set_tooltip_text("Notificações (placeholder)")
        btn_notif.connect("clicked", lambda _: spawn_app(["dunstctl", "history-pop"]))
        main_box.pack_end(btn_notif, False, False, 0)

        # Ícone de rede — wrapper funcional (abre nm-connection-editor)
        btn_net = Gtk.Button()
        btn_net.get_style_context().add_class("status-btn")
        btn_net.add(Gtk.Image.new_from_icon_name(
            "network-wireless-symbolic", Gtk.IconSize.MENU
        ))
        btn_net.set_tooltip_text("Rede")
        btn_net.connect("clicked", lambda _: spawn_app(["nm-connection-editor"]))
        main_box.pack_end(btn_net, False, False, 0)

        # Ícone de volume — wrapper funcional (abre flavos-osd)
        btn_vol = Gtk.Button()
        btn_vol.get_style_context().add_class("status-btn")
        btn_vol.add(Gtk.Image.new_from_icon_name(
            "audio-volume-medium-symbolic", Gtk.IconSize.MENU
        ))
        btn_vol.set_tooltip_text("Volume")
        btn_vol.connect("clicked", lambda _: spawn_app(["flavos-osd", "volume"]))
        main_box.pack_end(btn_vol, False, False, 0)

        # Separador direito (mais à esquerda do grupo pack_end = entre tasklist e status)
        sep_right = Gtk.Separator(orientation=Gtk.Orientation.VERTICAL)
        sep_right.get_style_context().add_class("task-sep")
        main_box.pack_end(sep_right, False, False, 0)

        # Inicia relógio
        self.update_clock()
        GLib.timeout_add_seconds(30, self.update_clock)

    def update_clock(self):
        now = datetime.now()
        # Formato: <hora>\n<data>
        # Usa Pango markup para destacar a hora suavemente
        self.lbl_clock.set_markup(now.strftime("<b>%H:%M</b>\n<span size='smaller'>%d/%m/%Y</span>"))
        return True


if __name__ == "__main__":
    import traceback
    try:
        win = FlavosTaskbar()
        win.show_all()
        Gtk.main()
    except Exception as e:
        print(f"[flavos-taskbar] CRASH: {e}", file=sys.stderr)
        traceback.print_exc(file=sys.stderr)
        sys.exit(1)
