#!/usr/bin/env python3
# Flavos Native Taskbar v2 (Etapa 11C / Refactor Robusto)
# Barra inferior utilizando núcleo nativo de baixo nível do Wnck.Tasklist.
# A Tasklist já assume gerenciamento maduro do protocolo de janelas X11.

import gi
import os
import sys

import json

# Exit silently in Wayland to prevent PAGER crash loops during transition
if os.environ.get("XDG_SESSION_TYPE", "x11") != "x11":
    print("[flavos-taskbar] Ignorado: Wayland ou shell não-X11 detectado.")
    sys.exit(0)

gi.require_version('Gtk', '3.0')
# Importante: Precisamos setar o tipo de cliente ANTES do Wnck ser instanciado e hookado
gi.require_version('Wnck', '3.0')
from gi.repository import Gtk, Gdk, Wnck, GLib

# 1. Definir obrigatoriamente status de Pager para aceitação do XServer.
Wnck.set_client_type(Wnck.ClientType.PAGER)

CONFIG_PATH = os.path.expanduser("~/.config/flavos/panel.json")

def load_config():
    if os.path.exists(CONFIG_PATH):
        try:
            with open(CONFIG_PATH, "r") as f:
                return json.load(f)
        except:
            pass
    return {"opacity": 100, "alignment": "left", "style": "solid"}

# ── Design Tokens (CSS Architecture) ─────────────────────────────────────────
CSS_BASE = """
/* Fundo e borda superior */
#FlavosTaskbar {{
    background-color: {bg_color};
    border-top: 1px solid {border_color};
}}

/* 
   O Wnck.Tasklist nativo gera GtkButtons padrão.
   Vamos mirar nossos estilos globalmente dentro da hierarquia dele.
*/
#FlavosTaskbar WnckTasklist {
    margin: 4px;
}

#FlavosTaskbar WnckTasklist button {{
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 2px 10px;
    margin: 0px 2px;
    color: #8891A5;
    font-family: Inter, sans-serif;
    font-size: 12px;
    font-weight: 500;
    transition: background-color 120ms cubic-bezier(0.2, 0, 0, 1),
                color 120ms cubic-bezier(0.2, 0, 0, 1),
                border 120ms ease;
    border-bottom: 2px solid transparent; 
}}

#FlavosTaskbar WnckTasklist button:hover {{
    background-color: {hover_bg};
    color: #C8CDD8;
}}

#FlavosTaskbar WnckTasklist button:focus-visible {{
    outline: 2px solid #4B8BF5;
    outline-offset: 2px;
}}

#FlavosTaskbar WnckTasklist button:checked {{
    background-color: {active_bg};
    color: #E8ECF4;
    border-bottom: 2px solid #4B8BF5;
}}
"""

class FlavosTaskbar(Gtk.Window):
    def __init__(self):
        super().__init__(type=Gtk.WindowType.TOPLEVEL)
        self.set_name("FlavosTaskbar")
        self.set_title("Flavos Taskbar")
        self.set_decorated(False)
        self.set_resizable(False)
        self.set_accept_focus(False)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)
        self.set_type_hint(Gdk.WindowTypeHint.DOCK)

        # Setup Transparência / Visual
        cfg = load_config()
        style = cfg.get("style", "solid")
        opacity = float(cfg.get("opacity", 100)) / 100.0
        
        # Permitindo compositing visual no vidro
        if os.environ.get("XDG_SESSION_TYPE", "x11") == "x11" and style == "glass":
            self.set_app_paintable(True)
            screen_dk = self.get_screen()
            visual = screen_dk.get_rgba_visual()
            if visual and screen_dk.is_composited():
                self.set_visual(visual)

        bg_color = f"rgba(13, 16, 23, {opacity})" if style == "glass" else "#0D1017"
        border_color = f"rgba(30, 36, 51, {opacity})" if style == "glass" else "#1E2433"
        hover_bg = f"rgba(26, 31, 43, {min(1.0, opacity + 0.2)})" if style == "glass" else "#1A1F2B"
        active_bg = f"rgba(30, 36, 51, {min(1.0, opacity + 0.3)})" if style == "glass" else "#1E2433"
        
        css_final = CSS_BASE.format(
            bg_color=bg_color,
            border_color=border_color,
            hover_bg=hover_bg,
            active_bg=active_bg
        )

        # Provider CSS
        provider = Gtk.CssProvider()
        provider.load_from_data(css_final.encode("utf-8"))
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_USER
        )

        display = Gdk.Display.get_default()
        monitor = display.get_primary_monitor() or display.get_monitor(0)
        geom = monitor.get_geometry()
        
        # Geometria da barra inferior
        self.set_default_size(geom.width, 36)
        self.move(geom.x, geom.y + geom.height - 36)

        # Validando screen connection do Wnck (Core Safety)
        self._screen = Wnck.Screen.get_default()
        if not self._screen:
            print("[flavos-taskbar] CRITICAL: Falha ao obter a tela Wnck. O servidor X pode estar indisponível.", file=sys.stderr)
            sys.exit(1)

        # Container nativo do Wnck
        self.tasklist = Wnck.Tasklist.new()
        
        # Customizações recomendadas para ambiente moderno
        self.tasklist.set_grouping(Wnck.TasklistGroupingType.AUTO_GROUP) # Agrupa pelo app nativamente se encher
        self.tasklist.set_switch_workspace_on_unminimize(True)
        self.tasklist.set_include_all_workspaces(True)
        self.tasklist.set_button_relief(Gtk.ReliefStyle.NORMAL) # Deixa o Wnck gerir o icone padrão do Gtk
        
        # Ocultar label padrão se usar muito espaço e não mostrar ícones
        # Wnck exibe ícone nativamente em NORMAL.
        
        # Embrulha em um Gtk.Box e centraliza as propriedades
        self.main_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        self.main_box.pack_start(self.tasklist, True, True, 0)
        
        self.add(self.main_box)


if __name__ == "__main__":
    win = FlavosTaskbar()
    win.show_all()
    Gtk.main()
