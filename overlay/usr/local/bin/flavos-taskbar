#!/usr/bin/env python3
# Flavos Native Taskbar v3 (Etapa 11B — Redesign Moderno)
# Barra inferior: Dock híbrida com botão de menu, apps fixados e Wnck.Tasklist.
# Gerenciada pelo flavos-session-daemon.
#
# Decisão arquitetural:
#   - Relógio fica SOMENTE no painel superior (evitar duplicação poluída)
#   - Branding textual "FLAVOS" fica SOMENTE no painel superior (Gtk.Label)
#   - A taskbar inferior é funcional: menu icon + pinned apps + janelas abertas

import gi
import os
import sys
import json
import subprocess

# Guard: X11 only nesta fase
if os.environ.get("XDG_SESSION_TYPE", "x11") != "x11":
    print("[flavos-taskbar] Ignorado: sessão não-X11.")
    sys.exit(0)

gi.require_version('Gtk', '3.0')
gi.require_version('Wnck', '3.0')
from gi.repository import Gtk, Gdk, Wnck, GLib

# Obrigatório: anunciar como PAGER antes de qualquer uso do Wnck
Wnck.set_client_type(Wnck.ClientType.PAGER)

# ── Config ────────────────────────────────────────────────────────────────────
CONFIG_PATH = os.path.expanduser("~/.config/flavos/panel.json")

# Apps fixados na taskbar — estrutura organizada, não hardcoded espalhado.
# Cada entrada: (icon_name, command_argv, tooltip)
PINNED_APPS = [
    ("utilities-terminal", ["kitty"],               "Terminal"),
    ("system-file-manager", ["pcmanfm"],             "Arquivos"),
    ("accessories-text-editor", ["mousepad"],         "Editor de Texto"),
]

def load_config():
    if os.path.exists(CONFIG_PATH):
        try:
            with open(CONFIG_PATH, "r") as f:
                return json.load(f)
        except Exception:
            pass
    return {"opacity": 100, "alignment": "left", "style": "solid"}


# ── CSS ───────────────────────────────────────────────────────────────────────
# Motion tokens (system-motion-design skill):
#   - State feedback: 100ms, cubic-bezier(0.2, 0, 0, 1)  (fast, responsive)
#   - Hover emphasis: 120ms ease
#   - Active press:   80ms
# Graphic design skill:
#   - Surface: #0D1017 (shell base)
#   - Border:  #272D3D
#   - Text muted: #8891A5
#   - Text active: #E8ECF4
#   - Accent: #4B8BF5
#   - Hover surface: #1A1F2B

BASE_CSS_SOLID = """
#FlavosTaskbar {
    background-color: #0D1017;
    border-top: 1px solid #272D3D;
}

/* Botão de menu (ícone do Flavos/Start) */
button.menu-btn {
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 8px;
    padding: 4px 12px;
    margin: 2px 4px 2px 8px;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1);
}
button.menu-btn:hover {
    background-image: none;
    background-color: #1A1F2B;
}
button.menu-btn:active {
    background-image: none;
    background-color: #4B8BF5;
}

/* Apps fixados */
button.pinned-btn {
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 8px;
    padding: 4px 8px;
    margin: 2px 1px;
    transition: background-color 120ms ease,
                box-shadow 120ms ease;
}
button.pinned-btn:hover {
    background-image: none;
    background-color: #1A1F2B;
}
button.pinned-btn:active {
    background-image: none;
    background-color: rgba(75, 139, 245, 0.25);
}

/* Separador sutil entre pinned e tasklist */
separator.task-sep {
    background-color: #272D3D;
    min-width: 1px;
    margin-top: 8px;
    margin-bottom: 8px;
    margin-left: 6px;
    margin-right: 6px;
}

/* Wnck.Tasklist — janelas abertas */
#FlavosTaskbar WnckTasklist {
    background-color: transparent;
    background-image: none;
}

#FlavosTaskbar WnckTasklist button {
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 2px 10px;
    margin: 2px 1px;
    color: #8891A5;
    font-family: Inter, sans-serif;
    font-size: 12px;
    font-weight: 500;
    border-bottom: 2px solid transparent;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1),
                color 100ms cubic-bezier(0.2, 0, 0, 1),
                border-bottom-color 120ms ease;
}

#FlavosTaskbar WnckTasklist button:hover {
    background-image: none;
    background-color: #1A1F2B;
    color: #C8CDD8;
}

#FlavosTaskbar WnckTasklist button:focus-visible {
    background-image: none;
    outline: 2px solid #4B8BF5;
    outline-offset: 2px;
}

#FlavosTaskbar WnckTasklist button:checked {
    background-image: none;
    background-color: #1E2433;
    color: #E8ECF4;
    border-bottom: 2px solid #4B8BF5;
}
"""

BASE_CSS_GLASS = """
#FlavosTaskbar {{
    background-color: rgba(13, 16, 23, {alpha});
    border-top: 1px solid rgba(39, 45, 61, {alpha});
}}

button.menu-btn {{
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 8px;
    padding: 4px 12px;
    margin: 2px 4px 2px 8px;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1);
}}
button.menu-btn:hover {{
    background-image: none;
    background-color: rgba(26, 31, 43, {hover_alpha});
}}
button.menu-btn:active {{
    background-image: none;
    background-color: #4B8BF5;
}}

button.pinned-btn {{
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 8px;
    padding: 4px 8px;
    margin: 2px 1px;
    transition: background-color 120ms ease,
                box-shadow 120ms ease;
}}
button.pinned-btn:hover {{
    background-image: none;
    background-color: rgba(26, 31, 43, {hover_alpha});
}}
button.pinned-btn:active {{
    background-image: none;
    background-color: rgba(75, 139, 245, 0.25);
}}

separator.task-sep {{
    background-color: rgba(39, 45, 61, {alpha});
    min-width: 1px;
    margin-top: 8px;
    margin-bottom: 8px;
    margin-left: 6px;
    margin-right: 6px;
}}

#FlavosTaskbar WnckTasklist {{
    background-color: transparent;
    background-image: none;
}}

#FlavosTaskbar WnckTasklist button {{
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 6px;
    padding: 2px 10px;
    margin: 2px 1px;
    color: #8891A5;
    font-family: Inter, sans-serif;
    font-size: 12px;
    font-weight: 500;
    border-bottom: 2px solid transparent;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1),
                color 100ms cubic-bezier(0.2, 0, 0, 1),
                border-bottom-color 120ms ease;
}}

#FlavosTaskbar WnckTasklist button:hover {{
    background-image: none;
    background-color: rgba(26, 31, 43, {hover_alpha});
    color: #C8CDD8;
}}

#FlavosTaskbar WnckTasklist button:focus-visible {{
    background-image: none;
    outline: 2px solid #4B8BF5;
    outline-offset: 2px;
}}

#FlavosTaskbar WnckTasklist button:checked {{
    background-image: none;
    background-color: #1E2433;
    color: #E8ECF4;
    border-bottom: 2px solid #4B8BF5;
}}
"""


def spawn_app(argv):
    """Lança app em background, desacoplado do ciclo Gtk."""
    subprocess.Popen(argv, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


class FlavosTaskbar(Gtk.Window):
    def __init__(self):
        super().__init__(type=Gtk.WindowType.TOPLEVEL)
        self.set_name("FlavosTaskbar")
        self.set_title("Flavos Taskbar")
        self.set_decorated(False)
        self.set_resizable(False)
        self.set_accept_focus(False)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)
        self.set_type_hint(Gdk.WindowTypeHint.DOCK)

        # ── Config e CSS ──────────────────────────────────────────────────
        cfg = load_config()
        style = cfg.get("style", "solid")
        opacity = cfg.get("opacity", 100)

        if style == "glass":
            self.set_app_paintable(True)
            screen = self.get_screen()
            visual = screen.get_rgba_visual()
            if visual and screen.is_composited():
                self.set_visual(visual)

        if style == "glass":
            alpha_val = float(opacity) / 100.0
            hover_alpha_val = min(1.0, alpha_val + 0.25)
            css_str = BASE_CSS_GLASS.format(alpha=alpha_val, hover_alpha=hover_alpha_val)
        else:
            css_str = BASE_CSS_SOLID

        provider = Gtk.CssProvider()
        provider.load_from_data(css_str.encode("utf-8"))
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_USER
        )

        # ── Geometria ─────────────────────────────────────────────────────
        display = Gdk.Display.get_default()
        monitor = display.get_primary_monitor() or display.get_monitor(0)
        geom = monitor.get_geometry()
        self.set_default_size(geom.width, 40)
        self.move(geom.x, geom.y + geom.height - 40)

        # ── Wnck Screen ──────────────────────────────────────────────────
        self._screen = Wnck.Screen.get_default()
        if not self._screen:
            print("[flavos-taskbar] CRITICAL: Wnck.Screen indisponível.", file=sys.stderr)
            sys.exit(1)

        # ── Layout ────────────────────────────────────────────────────────
        # [ Menu ] [ Pin ] [ Pin ] [ | ] [ ---- Wnck.Tasklist ---- ]
        main_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        self.add(main_box)

        # 1. Botão de Menu (ícone, não texto — branding textual fica no panel superior)
        btn_menu = Gtk.Button()
        btn_menu.get_style_context().add_class("menu-btn")
        menu_icon = Gtk.Image.new_from_icon_name(
            "start-here-symbolic", Gtk.IconSize.LARGE_TOOLBAR
        )
        btn_menu.add(menu_icon)
        btn_menu.set_tooltip_text("Menu (Super)")
        btn_menu.connect("clicked", lambda _: spawn_app(
            ["/usr/local/bin/flavos-shellctl", "launcher", "toggle"]
        ))
        main_box.pack_start(btn_menu, False, False, 0)

        # 2. Apps Fixados (da lista PINNED_APPS — estrutura organizada)
        for icon_name, cmd, tooltip in PINNED_APPS:
            btn = Gtk.Button()
            btn.get_style_context().add_class("pinned-btn")
            img = Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.LARGE_TOOLBAR)
            btn.add(img)
            btn.set_tooltip_text(tooltip)
            btn.connect("clicked", lambda _, c=cmd: spawn_app(c))
            main_box.pack_start(btn, False, False, 0)

        # 3. Separador visual
        sep = Gtk.Separator(orientation=Gtk.Orientation.VERTICAL)
        sep.get_style_context().add_class("task-sep")
        main_box.pack_start(sep, False, False, 0)

        # 4. Wnck.Tasklist — núcleo funcional das janelas abertas
        tasklist = Wnck.Tasklist.new()
        tasklist.set_grouping(Wnck.TasklistGroupingType.AUTO_GROUP)
        tasklist.set_switch_workspace_on_unminimize(True)
        tasklist.set_include_all_workspaces(True)
        tasklist.set_button_relief(Gtk.ReliefStyle.NONE)
        main_box.pack_start(tasklist, True, True, 0)


if __name__ == "__main__":
    win = FlavosTaskbar()
    win.show_all()
    Gtk.main()
