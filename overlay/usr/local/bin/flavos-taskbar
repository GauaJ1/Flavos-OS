    background-color: rgba(255,255,255,0.08);
    min-width: 1px;
    margin: 8px 6px;
}

/* ── Wnck.Tasklist — janelas abertas ──────────────────────────────────── */
#FlavosTaskbar WnckTasklist {
    background-color: transparent;
    background-image: none;
}

#FlavosTaskbar WnckTasklist button {
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 6px;
    /* Limite de largura por aba — evita botões gigantes */
    min-width: 80px;
    max-width: 180px;
    padding: 0 10px;
    margin: 4px 1px;
    color: #8891A5;
    font-family: Inter, sans-serif;
    font-size: 12px;
    font-weight: 500;
    border-bottom: 2px solid transparent;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1),
                color 100ms cubic-bezier(0.2, 0, 0, 1),
                border-bottom-color 150ms ease;
}
#FlavosTaskbar WnckTasklist button:hover {
    background-image: none;
    background-color: rgba(255,255,255,0.07);
    color: #C8CDD8;
}
#FlavosTaskbar WnckTasklist button:focus-visible {
    background-image: none;
    outline: 2px solid #4B8BF5;
    outline-offset: -2px;
}
#FlavosTaskbar WnckTasklist button:checked {
    background-image: none;
    background-color: rgba(75, 139, 245, 0.12);
    color: #E8ECF4;
    border-bottom: 2px solid #4B8BF5;
}

/* ── Separador direita ─────────────────────────────────────────────────── */
separator.systray-sep {
    background-color: rgba(255,255,255,0.08);
    min-width: 1px;
    margin: 8px 6px;
}

/* ── Ícones de sistema (direita) ──────────────────────────────────────── */
button.systray-btn {
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 6px;
    min-width: 30px;
    min-height: 30px;
    padding: 0 5px;
    margin: 4px 1px;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1);
}
button.systray-btn:hover {
    background-image: none;
    background-color: rgba(255,255,255,0.07);
}
button.systray-btn:active {
    background-image: none;
    background-color: rgba(75, 139, 245, 0.2);
}

/* ── Relógio (direita) ─────────────────────────────────────────────────── */
label.taskbar-clock {
    font-family: Inter, sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: #C8CDD8;
    padding: 0 14px 0 6px;
}
"""

BASE_CSS_GLASS = """
#FlavosTaskbar {{
    background-color: rgba(13, 16, 23, {alpha});
    border-top: 1px solid rgba(255,255,255,0.06);
}}

button.menu-btn {{
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 8px;
    min-width: 40px;
    min-height: 32px;
    padding: 0 10px;
    margin: 4px 2px 4px 6px;
    transition: background-color 100ms cubic-bezier(0.2, 0, 0, 1);
}}
button.menu-btn:hover {{
    background-image: none;
    background-color: rgba(255,255,255,0.07);
