#!/usr/bin/env python3
# flavos-lockscreen — Flavos OS Premium Lock Screen (Etapa 13C.3)
#
# Visual: fundo desfocado + overlay escuro + relógio grande + campo de senha.
# Auth:   python3-pam (PAM do sistema, módulo "PAM" maiúsculo no Debian).
# Grab:   Gdk.Seat.grab() — captura teclado e ponteiro ao nível do X11.
# Fallback: se grab falhar ou PAM indisponível, exit 1 → caller usa i3lock.
#
# Dependências: python3-gi python3-pam scrot imagemagick
# NÃO usa python3-cairo / python3-gi-cairo — tudo via GTK puro + CSS.

import gi
gi.require_version('Gtk', '3.0')
gi.require_version('Gdk', '3.0')
gi.require_version('GdkPixbuf', '2.0')
from gi.repository import Gtk, Gdk, GdkPixbuf, GLib

import os
import sys
import subprocess
import threading
import datetime

# ── PAM ───────────────────────────────────────────────────────────────────────
# Debian python3-pam expõe o módulo como "PAM" (maiúsculo), não "pam".
try:
    import PAM as _PAM_module
    _PAM_OK = True
except ImportError:
    _PAM_OK = False

# ── CSS (todo visual via GTK CSS — sem cairo) ─────────────────────────────────
CSS = b"""
* {
    font-family: Inter, Cantarell, "Noto Sans", sans-serif;
}
.lock-overlay {
    background: rgba(13,16,23, 0.68);
}
.lock-clock {
    color: rgba(232,236,244, 0.95);
    font-size: 88px;
    font-weight: 700;
}
.lock-date {
    color: rgba(232,236,244, 0.50);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 1px;
}
.lock-avatar {
    background: rgba(17,22,32, 0.95);
    border: 2px solid rgba(61,187,164, 0.70);
    border-radius: 9999px;
    min-width: 68px;
    min-height: 68px;
}
.lock-avatar-letter {
    color: rgba(232,236,244, 0.92);
    font-size: 24px;
    font-weight: 700;
}
.lock-user {
    color: rgba(232,236,244, 0.72);
    font-size: 13px;
    font-weight: 500;
}
.lock-entry {
    background: rgba(255,255,255, 0.07);
    color: rgba(232,236,244, 0.95);
    border: 1px solid rgba(255,255,255, 0.14);
    border-radius: 9999px;
    padding: 10px 28px;
    font-size: 15px;
    min-width: 280px;
    caret-color: rgba(232,236,244, 0.80);
}
.lock-entry:focus {
    border-color: rgba(61,187,164, 0.75);
    box-shadow: 0 0 0 1px rgba(61,187,164, 0.25);
}
.lock-hint {
    color: rgba(232,236,244, 0.28);
    font-size: 11px;
}
.lock-error {
    color: rgba(245,166,35, 0.90);
    font-size: 11px;
}
"""

# ── Screenshot + blur ─────────────────────────────────────────────────────────
def _capture_background():
    """Captura a tela e aplica blur. Retorna Pixbuf ou None."""
    tmp = '/tmp/flavos-lock-bg.png'
    try:
        r = subprocess.run(
            ['scrot', '-z', '-o', tmp], timeout=4,
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )
        if r.returncode != 0:
            return None
        subprocess.run(
            ['convert', tmp, '-blur', '0x18', '-brightness-contrast', '-15x0', tmp],
            timeout=6, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )
        return GdkPixbuf.Pixbuf.new_from_file(tmp)
    except Exception:
        return None


# ── Main window ───────────────────────────────────────────────────────────────
class FlavosLockScreen(Gtk.Window):

    def __init__(self, pixbuf):
        super().__init__()
        self._user = os.environ.get('USER', 'flavos')
        self._busy = False

        # ── CSS ────────────────────────────────────────────────────────────
        provider = Gtk.CssProvider()
        provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        # ── Window ─────────────────────────────────────────────────────────
        self.set_title('flavos-lockscreen')
        self.set_decorated(False)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)
        self.set_keep_above(True)
        self.set_type_hint(Gdk.WindowTypeHint.SPLASHSCREEN)
        self.fullscreen()

        # ── Layout (Overlay) ───────────────────────────────────────────────
        root = Gtk.Overlay()
        self.add(root)

        # Layer 1: background image (Gtk.Image — sem cairo)
        if pixbuf:
            screen = Gdk.Screen.get_default()
            sw = screen.get_width()
            sh = screen.get_height()
            scaled = pixbuf.scale_simple(sw, sh, GdkPixbuf.InterpType.BILINEAR)
            bg_image = Gtk.Image.new_from_pixbuf(scaled)
        else:
            # Fallback: caixa preta se scrot falhar
            bg_image = Gtk.Box()
            bg_image.override_background_color(
                Gtk.StateFlags.NORMAL,
                Gdk.RGBA(0.051, 0.063, 0.090, 1.0)
            )
        bg_image.set_hexpand(True)
        bg_image.set_vexpand(True)
        root.add(bg_image)

        # Layer 2: dark overlay (Gtk.Box com CSS rgba)
        dark = Gtk.Box()
        dark.get_style_context().add_class('lock-overlay')
        dark.set_hexpand(True)
        dark.set_vexpand(True)
        root.add_overlay(dark)

        # Layer 3: content (relógio + auth)
        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        content.set_halign(Gtk.Align.CENTER)
        content.set_valign(Gtk.Align.CENTER)
        root.add_overlay(content)

        # ── Clock ──────────────────────────────────────────────────────────
        self._clock = Gtk.Label()
        self._clock.get_style_context().add_class('lock-clock')
        content.pack_start(self._clock, False, False, 0)

        self._date = Gtk.Label()
        self._date.get_style_context().add_class('lock-date')
        content.pack_start(self._date, False, False, 8)

        # Spacer
        content.pack_start(Gtk.Box(height_request=48), False, False, 0)

        # ── Auth block ─────────────────────────────────────────────────────
        auth = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        auth.set_halign(Gtk.Align.CENTER)
        content.pack_start(auth, False, False, 0)

        # Avatar (círculo via CSS border-radius, sem cairo)
        avatar_frame = Gtk.Box()
        avatar_frame.set_halign(Gtk.Align.CENTER)
        avatar_circle = Gtk.Box()
        avatar_circle.get_style_context().add_class('lock-avatar')
        avatar_circle.set_size_request(72, 72)
        letter = Gtk.Label(label=(self._user or 'F')[0].upper())
        letter.get_style_context().add_class('lock-avatar-letter')
        letter.set_halign(Gtk.Align.CENTER)
        letter.set_valign(Gtk.Align.CENTER)
        avatar_circle.pack_start(letter, True, True, 0)
        avatar_frame.pack_start(avatar_circle, False, False, 0)
        auth.pack_start(avatar_frame, False, False, 0)

        # Username
        user_label = Gtk.Label(label=self._user)
        user_label.get_style_context().add_class('lock-user')
        auth.pack_start(user_label, False, False, 0)

        # Password entry
        self._entry = Gtk.Entry()
        self._entry.set_visibility(False)
        self._entry.set_placeholder_text('Senha…')
        self._entry.set_alignment(0.5)
        self._entry.get_style_context().add_class('lock-entry')
        self._entry.connect('activate', self._on_activate)
        auth.pack_start(self._entry, False, False, 4)

        # Status label
        self._status = Gtk.Label(label='')
        self._status.get_style_context().add_class('lock-hint')
        auth.pack_start(self._status, False, False, 0)

        # ── Signals ────────────────────────────────────────────────────────
        self.connect('destroy', Gtk.main_quit)
        self.connect('realize', self._on_realize)
        self._update_clock()
        GLib.timeout_add(1000, self._update_clock)

    # ── Clock ──────────────────────────────────────────────────────────────

    def _update_clock(self):
        now = datetime.datetime.now()
        self._clock.set_text(now.strftime('%H:%M'))
        self._date.set_text(now.strftime('%A, %-d de %B de %Y'))
        return True

    # ── Grab ───────────────────────────────────────────────────────────────

    def _on_realize(self, *_):
        GLib.timeout_add(150, self._do_grab)

    def _do_grab(self):
        gdk_win = self.get_window()
        if gdk_win is None:
            return False
        seat = self.get_display().get_default_seat()
        status = seat.grab(
            gdk_win,
            Gdk.SeatCapabilities.ALL,
            True, None, None, None, None
        )
        if status != Gdk.GrabStatus.SUCCESS:
            sys.stderr.write(
                f'flavos-lockscreen: grab failed ({status}) — aborting\n'
            )
            sys.stderr.flush()
            Gtk.main_quit()
            sys.exit(1)
        self._entry.grab_focus()
        return False

    # ── Auth ───────────────────────────────────────────────────────────────

    def _on_activate(self, entry):
        if self._busy:
            return
        password = entry.get_text()
        if not password:
            return
        self._busy = True
        self._set_status('Verificando…', 'lock-hint')
        entry.set_sensitive(False)
        threading.Thread(
            target=self._auth, args=(password,), daemon=True
        ).start()

    def _auth(self, password):
        """Autentica via PAM (Debian python3-pam: módulo PAM)."""
        ok = False
        if _PAM_OK:
            try:
                def _conv(auth, query_list, userData):
                    resp = []
                    for query, qtype in query_list:
                        if qtype in (_PAM_module.PAM_PROMPT_ECHO_OFF,
                                     _PAM_module.PAM_PROMPT_ECHO_ON):
                            resp.append((password, 0))
                        else:
                            resp.append(('', 0))
                    return resp
                p = _PAM_module.pam()
                p.start('login')
                p.set_item(_PAM_module.PAM_USER, self._user)
                p.set_item(_PAM_module.PAM_CONV, _conv)
                p.authenticate()
                p.acct_mgmt()
                ok = True
            except _PAM_module.error:
                ok = False
            except Exception:
                ok = False
        GLib.idle_add(self._auth_done, ok)

    def _auth_done(self, ok):
        if ok:
            Gtk.main_quit()
        else:
            self._set_status('Senha incorreta.', 'lock-error')
            self._entry.set_text('')
            self._entry.set_sensitive(True)
            self._entry.grab_focus()
            self._shake()
        self._busy = False

    def _set_status(self, text, css_class):
        ctx = self._status.get_style_context()
        for c in ('lock-hint', 'lock-error'):
            ctx.remove_class(c)
        ctx.add_class(css_class)
        self._status.set_text(text)

    def _shake(self):
        """Shake horizontal no campo de senha (erro de autenticação)."""
        offsets = [10, -10, 8, -8, 4, -4, 0]

        def _step(offs):
            self._entry.set_margin_start(max(0, offs))
            self._entry.set_margin_end(max(0, -offs))

        delay = 0
        for o in offsets:
            GLib.timeout_add(delay, lambda v=o: (_step(v), False)[1])
            delay += 40


# ── Entry point ───────────────────────────────────────────────────────────────
def main():
    if not _PAM_OK:
        sys.stderr.write('flavos-lockscreen: python3-pam não encontrado\n')
        sys.exit(1)

    # Capturar screenshot ANTES de mostrar a janela
    pixbuf = _capture_background()

    win = FlavosLockScreen(pixbuf)
    win.show_all()
    Gtk.main()


if __name__ == '__main__':
    main()
