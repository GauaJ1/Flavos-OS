#!/usr/bin/env python3
# Flavos Native Launcher (Etapa 11C)
# Design Centralizado, efêmero (mata e morre), sem menus em árvore.

import gi
import os
import sys
import subprocess

gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk, GLib, Gio

CSS = """
#LauncherWindow {
    background-color: rgba(22, 26, 33, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.6);
}

#SearchEntry {
    font-family: Inter, sans-serif;
    font-size: 14px;
    padding: 12px 18px;
    background-color: transparent;
    color: #E8ECF4;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    box-shadow: none;
}
#SearchEntry:focus {
    border: 1px solid rgba(255, 255, 255, 0.15);
    background-color: rgba(255, 255, 255, 0.02);
}

/* Quick Actions / Pinned (Quadrados Superiores) */
button.action-btn {
    background-image: none;
    background-color: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.03);
    border-radius: 16px;
    padding: 16px;
    transition: all 0.15s ease;
}
button.action-btn:hover, button.action-btn:focus {
    background-color: rgba(0, 0, 0, 0.4);
    border-color: rgba(255, 255, 255, 0.1);
}

label.action-label {
    font-family: Inter, sans-serif;
    font-size: 12px;
    color: #6C7A8C;
    margin-top: 8px;
}

/* App Grid Principal */
button.app-btn {
    background-image: none;
    background-color: transparent;
    border: none;
    border-radius: 16px;
    padding: 12px;
    transition: all 0.15s ease;
}
button.app-btn:hover, button.app-btn:focus {
    background-color: rgba(255, 255, 255, 0.05);
}

label.app-label {
    font-family: Inter, sans-serif;
    font-size: 12px;
    color: #8891A5;
    margin-top: 8px;
}

/* Botão Show All Applications */
button.show-all-btn {
    font-family: Inter, sans-serif;
    font-size: 13px;
    color: #8891A5;
    background-color: transparent;
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 24px;
    padding: 10px 24px;
    margin-top: 16px;
    transition: all 0.15s ease;
}
button.show-all-btn:hover {
    background-color: rgba(255, 255, 255, 0.05);
    color: #E8ECF4;
}
"""

PINNED_APPS = ["flavos-terminal.desktop", "flavos-files.desktop", "flavos-settings.desktop"]

def get_installed_apps():
    """Retorna lista de dicionarios com Gio.AppInfo."""
    apps = []
    for app in Gio.AppInfo.get_all():
        if app.should_show():
            apps.append({
                "name": app.get_display_name() or "",
                "id": app.get_id(),
                "icon": app.get_icon(),
                "appinfo": app
            })
    # Remove duplicates by id
    unique = {}
    for a in apps:
        if a["id"] not in unique:
            unique[a["id"]] = a
    return sorted(list(unique.values()), key=lambda x: x["name"].lower())


class FlavosLauncher(Gtk.Window):
    def __init__(self):
        super().__init__(type=Gtk.WindowType.TOPLEVEL)
        self.set_name("LauncherWindow")
        self.set_title("Flavos Launcher")
        self.set_default_size(700, 560)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.set_decorated(False)
        self.set_resizable(False)
        
        # Ignorado por gerenciadores tilling/etc e força float
        self.set_type_hint(Gdk.WindowTypeHint.DIALOG)
        
        self.set_app_paintable(True)
        screen = self.get_screen()
        visual = screen.get_rgba_visual()
        if visual and screen.is_composited():
            self.set_visual(visual)

        # Eventos vitais
        self.connect("focus-out-event", self.on_focus_out)
        self.connect("key-press-event", self.on_key_press)

        # Carrega CSS
        provider = Gtk.CssProvider()
        provider.load_from_data(CSS.encode('utf-8'))
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_USER
        )

        self.apps_data = get_installed_apps()

        # Layout Principal
        main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=24)
        main_box.set_margin_top(32)
        main_box.set_margin_bottom(32)
        main_box.set_margin_start(32)
        main_box.set_margin_end(32)
        self.add(main_box)

        # 1. Busca
        search_hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        main_box.pack_start(search_hbox, False, False, 0)

        self.search_entry = Gtk.SearchEntry()
        self.search_entry.set_name("SearchEntry")
        self.search_entry.set_placeholder_text("Search apps and settings...")
        self.search_entry.connect("search-changed", self.on_search_changed)
        search_hbox.pack_start(self.search_entry, True, True, 0)
        
        # Link discreto extra "All Apps >" nativo
        btn_all_apps_txt = Gtk.Label(label="All Apps >")
        btn_all_apps_txt.get_style_context().add_class("action-label")
        btn_all_apps_txt.set_margin_start(16)
        search_hbox.pack_start(btn_all_apps_txt, False, False, 0)

        # 2. Pinned & Actions (Primeira linha / 5 items da referencia)
        self.pinned_flow = Gtk.FlowBox()
        self.pinned_flow.set_selection_mode(Gtk.SelectionMode.NONE)
        self.pinned_flow.set_max_children_per_line(5)
        self.pinned_flow.set_min_children_per_line(5)
        self.pinned_flow.set_column_spacing(16)
        self.pinned_flow.set_row_spacing(16)
        self.pinned_flow.set_homogeneous(True)
        main_box.pack_start(self.pinned_flow, False, False, 0)

        # 3. Main Grid Apps Restantes (Duas Linhas 10 items da ref)
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroll.get_style_context().add_class("launcher-scroll")
        # Altura forcada p/ duas/tres camadas visiveis sem rolar
        scroll.set_min_content_height(250)
        main_box.pack_start(scroll, True, True, 0)

        self.apps_flow = Gtk.FlowBox()
        self.apps_flow.set_selection_mode(Gtk.SelectionMode.NONE)
        self.apps_flow.set_max_children_per_line(5)
        self.apps_flow.set_min_children_per_line(5)
        self.apps_flow.set_column_spacing(16)
        self.apps_flow.set_row_spacing(16)
        self.apps_flow.set_homogeneous(True)
        scroll.add(self.apps_flow)

        # 4. Show All Applications Bottom Pill
        self.btn_show_all = Gtk.Button(label="Show All Applications")
        self.btn_show_all.get_style_context().add_class("show-all-btn")
        # Centering it perfectly
        bottom_align = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        bottom_align.pack_start(self.btn_show_all, True, False, 0)
        main_box.pack_start(bottom_align, False, False, 0)

        self.populate_grids()

    def populate_grids(self):
        # A. Inject Quick Actions no Pinned Flow
        # Seguindo a foto: Terminal, Settings, Info, Restart, Lock
        
        # 1. Pinned App: Terminal
        term_match = next((a for a in self.apps_data if "terminal" in a["id"].lower()), None)
        if term_match: self.pinned_flow.add(self.create_grid_btn(term_match, is_action=True))
        
        # 2. Pinned App: Settings
        set_match = next((a for a in self.apps_data if "settings" in a["id"].lower()), None)
        if set_match: self.pinned_flow.add(self.create_grid_btn(set_match, is_action=True))
        
        # 3. Action: Info
        self.pinned_flow.add(self.create_custom_action("Info", "dialog-information-symbolic", ["flavos-settings"]))
        
        # 4. Action: Restart
        self.pinned_flow.add(self.create_custom_action("Restart", "system-reboot-symbolic", ["flavos-shellctl", "session", "reboot"]))
        
        # 5. Action: Lock
        self.pinned_flow.add(self.create_custom_action("Lock", "system-lock-screen-symbolic", ["flavos-shellctl", "session", "lock"]))

        # B. Popula Main Grade de Apps Excluindo os pinados
        pinned_ids = [a["id"] for a in self.apps_data if ("terminal" in a["id"].lower() or "settings" in a["id"].lower())]
        
        for app in self.apps_data:
            if app["id"] not in pinned_ids:
                self.apps_flow.add(self.create_grid_btn(app, is_action=False))

        self.pinned_flow.show_all()
        self.apps_flow.show_all()
        
    def create_custom_action(self, label_str, icon_name, cmd_args):
        btn = Gtk.Button()
        btn.get_style_context().add_class("action-btn")
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        btn.add(vbox)
        
        icon_w = Gtk.Image.new_from_icon_name(icon_name, Gtk.IconSize.DIALOG)
        icon_w.set_pixel_size(32)
        vbox.pack_start(icon_w, False, False, 0)
        
        lbl = Gtk.Label(label=label_str)
        lbl.get_style_context().add_class("action-label")
        vbox.pack_start(lbl, False, False, 0)
        
        btn.connect("clicked", lambda _: self.exec_action(cmd_args))
        return btn

    def create_grid_btn(self, app_data, is_action=False):
        btn = Gtk.Button()
        # Se for no flowbox de Pinned (Acoes rapidas no mock), usa o css action-btn, senão app-btn
        css_class = "action-btn" if is_action else "app-btn"
        lbl_class = "action-label" if is_action else "app-label"
        btn.get_style_context().add_class(css_class)
        
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        btn.add(vbox)

        # App Icon
        icon_w = Gtk.Image()
        icon = app_data["icon"]
        if icon:
            icon_w.set_from_gicon(icon, Gtk.IconSize.DIALOG)
        else:
            icon_w.set_from_icon_name("application-x-executable", Gtk.IconSize.DIALOG)
            
        icon_w.set_pixel_size(32 if is_action else 48)
        vbox.pack_start(icon_w, False, False, 0)

        # App Label
        lbl = Gtk.Label(label=app_data["name"])
        lbl.get_style_context().add_class(lbl_class)
        lbl.set_ellipsize(max("end", 1)) # fake pango constant
        from gi.repository import Pango
        lbl.set_ellipsize(Pango.EllipsizeMode.END)
        lbl.set_max_width_chars(12)
        vbox.pack_start(lbl, False, False, 0)

        btn.connect("clicked", lambda _: self.launch_app(app_data["appinfo"]))
        return btn

    def launch_app(self, appinfo):
        try:
            appinfo.launch()
        except:
            pass
        sys.exit(0)

    def exec_action(self, cmd_args):
        subprocess.Popen(cmd_args)
        sys.exit(0)

    def on_search_changed(self, entry):
        term = entry.get_text().lower().strip()
        
        if not term:
            self.pinned_flow.show()
            self.btn_show_all.show()
        else:
            self.pinned_flow.hide()
            self.btn_show_all.hide()

        # Refiltra
        for child in self.apps_flow.get_children():
            child.destroy()
            
        for app in self.apps_data:
            if not term or term in app["name"].lower():
                self.apps_flow.add(self.create_grid_btn(app, is_action=False))
        self.apps_flow.show_all()

    def on_focus_out(self, widget, event):
        sys.exit(0)
        
    def on_key_press(self, widget, event):
        keyval = event.keyval
        if keyval == Gdk.KEY_Escape:
            sys.exit(0)
            
        # Pular pro painel abaixo usando Seta para Baixo a partir do Search
        if keyval == Gdk.KEY_Down and self.get_focus() == self.search_entry:
            if self.pinned_flow.is_visible() and self.pinned_flow.get_children():
                self.pinned_flow.get_children()[0].get_child().grab_focus()
                return True
            elif self.apps_flow.get_children():
                self.apps_flow.get_children()[0].get_child().grab_focus()
                return True
                
        # Enter direto do search box invoca o primeiro app da lista filtrada
        if keyval in (Gdk.KEY_Return, Gdk.KEY_KP_Enter) and self.get_focus() == self.search_entry:
            children = self.apps_flow.get_children()
            if children:
                # O FlowBox empacota o btn dento de um FlowBoxChild
                child_btn = children[0].get_child()
                if child_btn:
                    child_btn.clicked()
                return True
                
        return False

if __name__ == '__main__':
    win = FlavosLauncher()
    win.show_all()
    # Força captura de foco imediata assim que mapeado
    win.present()
    Gtk.main()
