#!/usr/bin/env python3
import gi
import os
import subprocess
import datetime
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk, GLib

LOG_DIR = os.path.expanduser("~/.local/share/flavos/logs")
os.makedirs(LOG_DIR, exist_ok=True)
LOG_FILE = os.path.join(LOG_DIR, "firstboot.log")

def log_action(msg):
    timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    with open(LOG_FILE, "a") as f:
        f.write(f"[{timestamp}] {msg}\n")
    print(msg)

class FlavosFirstBoot(Gtk.Window):
    def __init__(self):
        super().__init__(title="Flavos OS - Primeiro Boot")
        self.set_default_size(600, 500)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.set_border_width(20)

        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=15)
        self.add(vbox)

        # Welcome
        title_label = Gtk.Label(label="<span size='xx-large' weight='bold'>Bem-vindo ao Flavos OS</span>")
        title_label.set_use_markup(True)
        vbox.pack_start(title_label, False, False, 10)

        preview_label = Gtk.Label(label="Aviso: Esta é uma Preview Técnica. O sistema está em modo Installed-FirstBoot.")
        preview_label.set_line_wrap(True)
        vbox.pack_start(preview_label, False, False, 5)

        # Setup Container
        setup_frame = Gtk.Frame(label="Configurações Básicas (Simulação)")
        vbox.pack_start(setup_frame, True, True, 10)

        setup_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        setup_box.set_border_width(10)
        setup_frame.add(setup_box)

        # Hostname
        hostname_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        hostname_box.pack_start(Gtk.Label(label="Hostname:"), False, False, 0)
        self.hostname_entry = Gtk.Entry()
        self.hostname_entry.set_text(os.uname().nodename)
        hostname_box.pack_start(self.hostname_entry, True, True, 0)
        setup_box.pack_start(hostname_box, False, False, 0)

        # Performance Profile
        perf_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        perf_box.pack_start(Gtk.Label(label="Perfil de Performance:"), False, False, 0)
        self.perf_combo = Gtk.ComboBoxText()
        self.perf_combo.append_text("light")
        self.perf_combo.append_text("balanced")
        self.perf_combo.append_text("full")
        self.perf_combo.set_active(1)
        perf_box.pack_start(self.perf_combo, True, True, 0)
        setup_box.pack_start(perf_box, False, False, 0)

        # User Account Info
        user_frame = Gtk.Frame(label="Conta de Usuário (Em Breve)")
        vbox.pack_start(user_frame, False, False, 10)
        user_label = Gtk.Label(label="A criação de usuário e remoção do autologin de desenvolvimento será habilitada nas próximas etapas (14H.2 ou 14I). O usuário atual ('flavos') foi mantido intacto por segurança.")
        user_label.set_line_wrap(True)
        user_label.set_margin_top(10)
        user_label.set_margin_bottom(10)
        user_label.set_margin_start(10)
        user_label.set_margin_end(10)
        user_frame.add(user_label)

        # Action Buttons
        button_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        button_box.set_halign(Gtk.Align.END)
        vbox.pack_end(button_box, False, False, 0)

        btn_later = Gtk.Button(label="Concluir depois")
        btn_later.connect("clicked", self.on_later_clicked)
        button_box.pack_start(btn_later, False, False, 0)

        btn_finish = Gtk.Button(label="Finalizar")
        btn_finish.get_style_context().add_class("suggested-action")
        btn_finish.connect("clicked", self.on_finish_clicked)
        button_box.pack_start(btn_finish, False, False, 0)

        self.connect("destroy", Gtk.main_quit)

    def on_later_clicked(self, widget):
        log_action("OOBE adiado ('Concluir depois' clicado).")
        Gtk.main_quit()

    def on_finish_clicked(self, widget):
        hostname = self.hostname_entry.get_text()
        perf = self.perf_combo.get_active_text()
        log_action(f"OOBE simulação: Hostname={hostname}, Performance={perf}")
        
        # Usa pkexec em vez de sudo: funciona em sessões gráficas sem TTY.
        # A policy org.flavos.firstboot.policy permite allow_active=yes
        # (usuário local ativo) sem prompt de senha via lxpolkit.
        log_action("Iniciando finalização via pkexec helper...")
        try:
            result = subprocess.run(
                ["pkexec", "/usr/local/lib/flavos/helpers/flavos-firstboot-complete"],
                capture_output=True, text=True
            )
            if result.returncode != 0:
                raise subprocess.CalledProcessError(result.returncode, "pkexec", result.stderr)

            log_action("Finalização concluída com sucesso. Marcador 'firstboot-complete' criado.")

            dialog = Gtk.MessageDialog(
                transient_for=self,
                flags=0,
                message_type=Gtk.MessageType.INFO,
                buttons=Gtk.ButtonsType.OK,
                text="Configuração Concluída"
            )
            dialog.format_secondary_text(
                "A configuração inicial foi finalizada.\n"
                "O assistente não aparecerá mais nos próximos boots."
            )
            dialog.run()
            dialog.destroy()
            Gtk.main_quit()

        except subprocess.CalledProcessError as e:
            log_action(f"Falha ao executar o helper de conclusão: {e}")
            dialog = Gtk.MessageDialog(
                transient_for=self,
                flags=0,
                message_type=Gtk.MessageType.ERROR,
                buttons=Gtk.ButtonsType.OK,
                text="Erro ao Concluir"
            )
            stderr_detail = e.stderr.strip() if hasattr(e, "stderr") and e.stderr else str(e)
            dialog.format_secondary_text(
                f"Falha ao chamar o helper de OOBE.\n"
                f"Verifique os logs em ~/.local/share/flavos/logs/firstboot.log\n\n"
                f"Detalhe: {stderr_detail}"
            )
            dialog.run()
            dialog.destroy()

if __name__ == "__main__":
    app = FlavosFirstBoot()
    app.show_all()
    Gtk.main()
