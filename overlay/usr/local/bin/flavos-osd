#!/usr/bin/env python3
# Flavos OS — OSD v5 (Etapa 11D — Native Visual Feedback System)
#
# Hierarquia de superfícies de feedback:
#   OSD   → Volume, Brilho — feedback imediato de hardware
#         → Posição: centro-horizontal, acima da taskbar
#   Toast → Canal de feedback interno da shell Flavos OS
#         → NÃO substitui dunst — exclusivo para eventos de shell
#         → Posição: canto inferior direito, acima da taskbar
#
# Singleton via PID file /tmp/flavos-osd.pid:
#   Nova invocação mata instância anterior via SIGKILL antes de abrir.
#   Resolve disparos rápidos (ex: segurar volume) sem instâncias concorrentes.
#
# Motion (system-motion-design.md):
#   Entrada: 120ms ease-out | opacity 0→1 + slide Y +8px→0
#   Saída:   100ms ease-in  | opacity 1→0 + slide Y 0→+8px
#   Fallback VM: pure opacity fade (is_composited() == False → sem move)
#
# Brilho (honesto):
#   Lê /sys/class/backlight. Se indisponível (VM, monitor externo),
#   exibe estado "Não disponível" — sem fingir ajuste funcional.

import gi
import sys
import os
import re
import signal
import atexit
import subprocess

gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk, GLib

# ─── Constantes ───────────────────────────────────────────────────────────────
OSD_PID_FILE    = "/tmp/flavos-osd.pid"
OSD_TIMEOUT_MS  = 1800   # Auto-dismiss para OSD de hardware
TOAST_TIMEOUT_MS = 3000  # Auto-dismiss para Toast de shell

# Motion tokens (system-motion-design.md — categoria B: panel/popover)
ENTER_MS  = 120   # Entrada: ease-out
EXIT_MS   = 100   # Saída: ease-in (mais decisiva, menos teatral)
TICK_MS   = 16    # ~60fps — GLib.timeout_add, não bloqueante
SLIDE_Y   = 8     # px de deslocamento vertical (discreto, não dramático)

# Geometria da shell (espelha rc.xml margins)
TASKBAR_H = 36    # Taskbar inferior
PANEL_H   = 32    # Painel superior

# ─── CSS — Design System Flavos OS ────────────────────────────────────────────
# Glass semi-transparente: rgba(22,26,33,0.88) + blur do Picom por baixo.
# Fundo solido foi substituido para consistencia com Panel e Launcher.
CSS = """
/* -- OSD: Volume / Brilho -- */
