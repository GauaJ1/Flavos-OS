#!/usr/bin/env python3
# Flavos OS — Shell OSD v3 (corrigido)
# Componente visual PRÓPRIO da shell, sem dunst.
# Janela GTK efêmera, posicionada acima do painel.

import gi
import sys
import subprocess
import re
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk, GLib

CSS = b"""
window {
    background-color: #0D1017;
    border: 1px solid #272D3D;
    border-radius: 12px;
}
label {
    color: #E8ECF4;
    background-color: transparent;
}
.osd-title {
    font-size: 10px;
    font-weight: 700;
    color: #8891A5;
}
.osd-value {
    font-size: 26px;
    font-weight: 700;
    color: #E8ECF4;
}
.osd-muted {
    font-size: 26px;
    font-weight: 700;
    color: #505872;
}
progressbar trough {
    background-color: #1C2030;
    border-radius: 3px;
    min-height: 5px;
}
progressbar progress {
    background-color: #4B8BF5;
    border-radius: 3px;
    min-height: 5px;
}
"""

OSD_TIMEOUT_MS = 1800


def get_volume():
    """Retorna (nível 0-100, is_muted). Retorna (-1, False) se sem áudio."""
    try:
        out = subprocess.check_output(
            ["amixer", "sget", "Master"],
            text=True, stderr=subprocess.DEVNULL, timeout=2
        )
        vol_match = re.search(r'\[(\d+)%\]', out)
        if not vol_match:
            return -1, False
        muted = '[off]' in out
        return int(vol_match.group(1)), muted
    except (FileNotFoundError, subprocess.TimeoutExpired, subprocess.CalledProcessError):
        return -1, False


def set_volume(delta=0, toggle_mute=False):
    try:
        if toggle_mute:
            subprocess.run(
                ["amixer", "-q", "sset", "Master", "toggle"],
                stderr=subprocess.DEVNULL, timeout=2
            )
        elif delta > 0:
            subprocess.run(
                ["amixer", "-q", "sset", "Master", f"{abs(delta)}%+", "unmute"],
                stderr=subprocess.DEVNULL, timeout=2
            )
        elif delta < 0:
            subprocess.run(
                ["amixer", "-q", "sset", "Master", f"{abs(delta)}%-", "unmute"],
                stderr=subprocess.DEVNULL, timeout=2
            )
    except Exception:
        pass


class ShellOSD(Gtk.Window):
    def __init__(self, title_text, value_text, fraction=-1.0, is_muted=False, is_unavailable=False):
        super().__init__(type=Gtk.WindowType.POPUP)
        self.set_decorated(False)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)
        self.set_keep_above(True)
        self.set_accept_focus(False)
        self.set_resizable(False)

        width = 220

        screen = Gdk.Screen.get_default()
        sw = screen.get_width()
        sh = screen.get_height()
        # Centralizado horizontalmente, 100px acima do painel (42px)
        self.move((sw - width) // 2, sh - 42 - 100 - 20)
        self.set_default_size(width, 1)

        css_provider = Gtk.CssProvider()
        css_provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            screen, css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_USER
        )

        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        vbox.set_margin_top(16)
        vbox.set_margin_bottom(16)
        vbox.set_margin_start(20)
        vbox.set_margin_end(20)
        self.add(vbox)

        lbl_title = Gtk.Label(label=title_text.upper(), xalign=0)
        lbl_title.get_style_context().add_class("osd-title")
        vbox.pack_start(lbl_title, False, False, 0)

        lbl_value = Gtk.Label(label=value_text, xalign=0)
        if is_muted:
            lbl_value.get_style_context().add_class("osd-muted")
        else:
            lbl_value.get_style_context().add_class("osd-value")
        vbox.pack_start(lbl_value, False, False, 0)

        if fraction >= 0:
            bar = Gtk.ProgressBar()
            bar.set_fraction(max(0.0, min(1.0, fraction)))
            vbox.pack_start(bar, False, False, 2)

        GLib.timeout_add(OSD_TIMEOUT_MS, self._dismiss)

    def _dismiss(self):
        self.destroy()
        Gtk.main_quit()
        return False


def show_volume_osd():
    vol, muted = get_volume()
    if vol < 0:
        osd = ShellOSD("Volume", "—", is_unavailable=True)
    elif muted:
        osd = ShellOSD("Volume", "Mudo", fraction=vol / 100.0, is_muted=True)
    else:
        osd = ShellOSD("Volume", f"{vol}%", fraction=vol / 100.0)
    osd.show_all()
    Gtk.main()


def main():
    if len(sys.argv) < 2:
        print("Uso: flavos-osd {volume|volume-up|volume-down|volume-mute|brightness}")
        sys.exit(1)

    cmd = sys.argv[1]
    if cmd == "volume":
        show_volume_osd()
    elif cmd == "volume-up":
        set_volume(delta=5)
        show_volume_osd()
    elif cmd == "volume-down":
        set_volume(delta=-5)
        show_volume_osd()
    elif cmd == "volume-mute":
        set_volume(toggle_mute=True)
        show_volume_osd()
    elif cmd == "brightness":
        osd = ShellOSD("Brilho", "—", is_unavailable=True)
        osd.show_all()
        Gtk.main()
    else:
        print(f"Comando desconhecido: {cmd}")
        sys.exit(1)


if __name__ == "__main__":
    main()
