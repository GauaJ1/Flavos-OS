#!/usr/bin/env python3
# Flavos OS — Shell OSD (On-Screen Display)
# Componente visual PRÓPRIO da shell. NÃO usa dunst/notificações.
# Renderiza overlay GTK efêmero para feedback de ações do sistema.
#
# Arquitetura:
#   A shell é dona do OSD. Notificações (dunst) são para eventos
#   de apps/sistema em segundo plano. OSD é feedback imediato de
#   ações do usuário em componentes da própria shell.
#
# Uso:
#   flavos-osd volume          — mostra nível atual
#   flavos-osd volume-up       — sobe 5% e mostra
#   flavos-osd volume-down     — desce 5% e mostra
#   flavos-osd volume-mute     — toggle mute e mostra
#   flavos-osd brightness      — placeholder

import gi
import sys
import subprocess
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk, GLib

CSS = b"""
* {
    -GtkWidget-focus-padding: 0;
    -GtkWidget-focus-line-width: 0;
    outline-style: none;
}

window, .background {
    background-color: rgba(13, 16, 23, 0.92);
    border: 1px solid #272D3D;
    border-radius: 12px;
}

label {
    color: #E8ECF4;
    font-family: Inter, sans-serif;
    background-color: transparent;
}

label.osd-title {
    font-size: 11px;
    font-weight: 600;
    color: #8891A5;
    letter-spacing: 1px;
}

label.osd-value {
    font-size: 28px;
    font-weight: 700;
    color: #E8ECF4;
}

label.osd-muted {
    font-size: 28px;
    font-weight: 700;
    color: #505872;
}

progressbar {
    min-height: 6px;
}

progressbar trough {
    background-color: #1C2030;
    border-radius: 3px;
    min-height: 6px;
}

progressbar progress {
    background-color: #4B8BF5;
    border-radius: 3px;
    min-height: 6px;
}
"""

OSD_TIMEOUT_MS = 1500  # 1.5s — motion.fast, efêmero


def get_volume():
    """Retorna (nível 0-100, is_muted)"""
    try:
        out = subprocess.check_output(
            ["amixer", "sget", "Master"], text=True, stderr=subprocess.DEVNULL
        )
        import re
        vol_match = re.search(r'\[(\d+)%\]', out)
        muted = '[off]' in out
        vol = int(vol_match.group(1)) if vol_match else 0
        return vol, muted
    except Exception:
        return -1, False


def set_volume(delta=0, toggle_mute=False):
    """Altera volume via amixer."""
    try:
        if toggle_mute:
            subprocess.run(["amixer", "-q", "sset", "Master", "toggle"],
                           stderr=subprocess.DEVNULL)
        elif delta > 0:
            subprocess.run(["amixer", "-q", "sset", "Master", f"{abs(delta)}%+", "unmute"],
                           stderr=subprocess.DEVNULL)
        elif delta < 0:
            subprocess.run(["amixer", "-q", "sset", "Master", f"{abs(delta)}%-", "unmute"],
                           stderr=subprocess.DEVNULL)
    except Exception:
        pass


class ShellOSD(Gtk.Window):
    """Janela efêmera da shell para feedback imediato."""

    def __init__(self, title_text, value_text, fraction=0.0, is_muted=False, is_unavailable=False):
        super().__init__(type=Gtk.WindowType.POPUP)
        self.set_decorated(False)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)
        self.set_keep_above(True)
        self.set_accept_focus(False)
        self.set_can_focus(False)
        self.set_default_size(220, 100)

        # Posição: centro inferior, acima do painel
        screen = Gdk.Screen.get_default()
        sw = screen.get_width()
        sh = screen.get_height()
        self.move((sw - 220) // 2, sh - 42 - 120)

        # CSS
        css_provider = Gtk.CssProvider()
        css_provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            screen, css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_USER
        )

        # Layout
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        vbox.set_margin_top(16)
        vbox.set_margin_bottom(16)
        vbox.set_margin_start(20)
        vbox.set_margin_end(20)
        self.add(vbox)

        # Título (ex: "VOLUME")
        lbl_title = Gtk.Label(label=title_text.upper(), xalign=0)
        lbl_title.get_style_context().add_class("osd-title")
        vbox.pack_start(lbl_title, False, False, 0)

        # Valor (ex: "75%" ou "Mudo")
        lbl_value = Gtk.Label(label=value_text, xalign=0)
        if is_muted or is_unavailable:
            lbl_value.get_style_context().add_class("osd-muted")
        else:
            lbl_value.get_style_context().add_class("osd-value")
        vbox.pack_start(lbl_value, False, False, 0)

        # Barra de progresso (se aplicável)
        if not is_unavailable and fraction >= 0:
            bar = Gtk.ProgressBar()
            bar.set_fraction(max(0.0, min(1.0, fraction)))
            bar.set_margin_top(4)
            vbox.pack_start(bar, False, False, 0)

        # Auto-destruição
        GLib.timeout_add(OSD_TIMEOUT_MS, self._dismiss)

    def _dismiss(self):
        self.destroy()
        Gtk.main_quit()
        return False


def show_volume_osd():
    vol, muted = get_volume()
    if vol < 0:
        osd = ShellOSD("Volume", "Indisponível", is_unavailable=True)
    elif muted:
        osd = ShellOSD("Volume", "Mudo", fraction=vol / 100.0, is_muted=True)
    else:
        osd = ShellOSD("Volume", f"{vol}%", fraction=vol / 100.0)
    osd.show_all()
    Gtk.main()


def show_brightness_osd():
    osd = ShellOSD("Brilho", "Indisponível", is_unavailable=True)
    osd.show_all()
    Gtk.main()


def main():
    if len(sys.argv) < 2:
        print("Flavos Shell OSD — uso: flavos-osd {volume|volume-up|volume-down|volume-mute|brightness}")
        sys.exit(1)

    cmd = sys.argv[1]

    if cmd == "volume":
        show_volume_osd()
    elif cmd == "volume-up":
        set_volume(delta=5)
        show_volume_osd()
    elif cmd == "volume-down":
        set_volume(delta=-5)
        show_volume_osd()
    elif cmd == "volume-mute":
        set_volume(toggle_mute=True)
        show_volume_osd()
    elif cmd == "brightness":
        show_brightness_osd()
    else:
        print(f"Comando desconhecido: {cmd}")
        sys.exit(1)


if __name__ == "__main__":
    main()
