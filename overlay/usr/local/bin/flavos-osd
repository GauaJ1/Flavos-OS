#!/usr/bin/env python3
# Flavos OS — Shell OSD v4
# Janela GTK popup efêmera. Fundo sólido, sem RGBA (evita artefatos de compositor).
# Volume: tenta pactl (PulseAudio/PipeWire), fallback para amixer (ALSA).

import gi
import sys
import subprocess
import re

gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk, GLib

# --- Design Tokens -------------------------------------------------------
# Fundo sólido — NÃO usa RGBA. O Picom aplica blur/shadow independentemente.
CSS = b"""
window {
    background-color: #1C2030;
    border-radius: 14px;
}
.osd-box {
    padding: 20px 24px 18px 24px;
    border: 1px solid #2E3652;
    border-radius: 14px;
    background-color: #1C2030;
}
.osd-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    color: #5A6480;
}
.osd-value {
    font-size: 36px;
    font-weight: 800;
    color: #E8ECF4;
    margin-top: 2px;
}
.osd-muted {
    font-size: 36px;
    font-weight: 800;
    color: #3A4560;
    margin-top: 2px;
}
progressbar {
    margin-top: 10px;
}
progressbar trough {
    background-color: #272D3D;
    border-radius: 4px;
    min-height: 6px;
    border: none;
}
progressbar progress {
    background-color: #4B8BF5;
    border-radius: 4px;
    min-height: 6px;
    border: none;
}
.osd-muted-bar progress {
    background-color: #2E3652;
}
"""

OSD_TIMEOUT_MS = 1800
# -------------------------------------------------------------------------


def _run(cmd):
    try:
        return subprocess.check_output(
            cmd, text=True, stderr=subprocess.DEVNULL, timeout=2
        ).strip()
    except Exception:
        return ""


# --- Volume backend: pactl first, amixer fallback ------------------------
def get_volume():
    """Retorna (level 0-100, is_muted). (-1, False) se indisponível."""
    # 1. PulseAudio / PipeWire via pactl
    out = _run(["pactl", "get-sink-volume", "@DEFAULT_SINK@"])
    if out:
        match = re.search(r'(\d+)%', out)
        if match:
            vol = int(match.group(1))
            mute_out = _run(["pactl", "get-sink-mute", "@DEFAULT_SINK@"])
            muted = "yes" in mute_out.lower()
            return vol, muted

    # 2. ALSA via amixer
    out = _run(["amixer", "sget", "Master"])
    if out:
        match = re.search(r'\[(\d+)%\]', out)
        if match:
            vol = int(match.group(1))
            muted = '[off]' in out
            return vol, muted

    return -1, False


def set_volume(delta=0, toggle_mute=False):
    """Ajusta volume. Usa pactl primeiro, amixer como fallback."""
    # PulseAudio / PipeWire
    try:
        if toggle_mute:
            subprocess.run(
                ["pactl", "set-sink-mute", "@DEFAULT_SINK@", "toggle"],
                stderr=subprocess.DEVNULL, timeout=2, check=False
            )
        elif delta > 0:
            subprocess.run(
                ["pactl", "set-sink-volume", "@DEFAULT_SINK@", f"+{abs(delta)}%"],
                stderr=subprocess.DEVNULL, timeout=2, check=False
            )
            subprocess.run(
                ["pactl", "set-sink-mute", "@DEFAULT_SINK@", "0"],
                stderr=subprocess.DEVNULL, timeout=2, check=False
            )
            # Clamp a 100% — pactl permite ir além disso
            subprocess.run(
                ["bash", "-c",
                 "vol=$(pactl get-sink-volume @DEFAULT_SINK@ | grep -oP '\\d+(?=%)' | head -1);"
                 "[ \"$vol\" -gt 100 ] && pactl set-sink-volume @DEFAULT_SINK@ 100%"],
                stderr=subprocess.DEVNULL, timeout=2, check=False
            )
        elif delta < 0:
            subprocess.run(
                ["pactl", "set-sink-volume", "@DEFAULT_SINK@", f"-{abs(delta)}%"],
                stderr=subprocess.DEVNULL, timeout=2, check=False
            )
            subprocess.run(
                ["pactl", "set-sink-mute", "@DEFAULT_SINK@", "0"],
                stderr=subprocess.DEVNULL, timeout=2, check=False
            )
        # Se pactl funcionou voltamos
        if _run(["pactl", "get-sink-volume", "@DEFAULT_SINK@"]):
            return
    except Exception:
        pass

    # Fallback: amixer
    try:
        if toggle_mute:
            subprocess.run(
                ["amixer", "-q", "sset", "Master", "toggle"],
                stderr=subprocess.DEVNULL, timeout=2, check=False
            )
        elif delta > 0:
            subprocess.run(
                ["amixer", "-q", "sset", "Master", f"{abs(delta)}%+", "unmute"],
                stderr=subprocess.DEVNULL, timeout=2, check=False
            )
        elif delta < 0:
            subprocess.run(
                ["amixer", "-q", "sset", "Master", f"{abs(delta)}%-", "unmute"],
                stderr=subprocess.DEVNULL, timeout=2, check=False
            )
    except Exception:
        pass
# -------------------------------------------------------------------------


class ShellOSD(Gtk.Window):
    def __init__(self, label_text, value_text, fraction=-1.0, is_muted=False):
        super().__init__(type=Gtk.WindowType.POPUP)
        self.set_decorated(False)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)
        self.set_keep_above(True)
        self.set_accept_focus(False)
        self.set_resizable(False)
        # WM_CLASS para regras do picom (set_wmclass deprecado; usa set_name)
        self.set_name("FlavosOSD")

        # Aplicar CSS
        css_provider = Gtk.CssProvider()
        css_provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_USER
        )

        # Posicionamento: centro horizontal, 160px acima do painel (42px)
        width = 240
        display = Gdk.Display.get_default()
        monitor = display.get_primary_monitor() or display.get_monitor(0)
        geo = monitor.get_geometry()
        x = geo.x + (geo.width - width) // 2
        y = geo.y + geo.height - 42 - 160
        self.move(x, y)
        self.set_default_size(width, 1)

        # Layout
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        outer.get_style_context().add_class("osd-box")
        self.add(outer)

        lbl_label = Gtk.Label(label=label_text.upper(), xalign=0)
        lbl_label.get_style_context().add_class("osd-label")
        outer.pack_start(lbl_label, False, False, 0)

        lbl_value = Gtk.Label(label=value_text, xalign=0)
        lbl_value.get_style_context().add_class(
            "osd-muted" if is_muted else "osd-value"
        )
        outer.pack_start(lbl_value, False, False, 0)

        if fraction >= 0:
            bar = Gtk.ProgressBar()
            bar.set_fraction(max(0.0, min(1.0, fraction)))
            if is_muted:
                bar.get_style_context().add_class("osd-muted-bar")
            outer.pack_start(bar, False, False, 0)

        GLib.timeout_add(OSD_TIMEOUT_MS, self._dismiss)

    def _dismiss(self):
        self.destroy()
        Gtk.main_quit()
        return False


def show_osd(label, value, fraction=-1.0, is_muted=False):
    osd = ShellOSD(label, value, fraction=fraction, is_muted=is_muted)
    osd.show_all()
    Gtk.main()


def show_volume_osd():
    vol, muted = get_volume()
    if vol < 0:
        show_osd("Volume", "—")
    elif muted:
        show_osd("Volume", "Mudo", fraction=vol / 100.0, is_muted=True)
    else:
        show_osd("Volume", f"{vol}%", fraction=vol / 100.0)


def main():
    if len(sys.argv) < 2:
        print("Uso: flavos-osd {volume|volume-up|volume-down|volume-mute}")
        sys.exit(1)

    cmd = sys.argv[1]
    if cmd == "volume":
        show_volume_osd()
    elif cmd == "volume-up":
        set_volume(delta=5)
        show_volume_osd()
    elif cmd == "volume-down":
        set_volume(delta=-5)
        show_volume_osd()
    elif cmd == "volume-mute":
        set_volume(toggle_mute=True)
        show_volume_osd()
    elif cmd == "brightness":
        show_osd("Brilho", "—")
    else:
        print(f"Comando desconhecido: {cmd}")
        sys.exit(1)


if __name__ == "__main__":
    main()
