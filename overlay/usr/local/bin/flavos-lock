#!/bin/bash
# flavos-lock — Wrapper central de bloqueio de sessão (Etapa 13C.3)
#
# Rota canônica: flavos-shellctl → flavos-lock → flavos-lockscreen (→ i3lock fallback)
# NÃO chame i3lock ou flavos-lockscreen diretamente de outros componentes.

set -u

LOG="${XDG_RUNTIME_DIR:-/tmp}/flavos-lock.log"
( umask 077; : >> "$LOG" ) 2>/dev/null || true

# ── Validação: sessão X11 ─────────────────────────────────────────────────────
if [ "${XDG_SESSION_TYPE:-x11}" != "x11" ]; then
    echo "$(date -Is) ERRO: lock só implementado para X11." >> "$LOG"
    exit 1
fi

export DISPLAY="${DISPLAY:-:0}"
if [ -z "${XAUTHORITY:-}" ] && [ -f "${HOME:-/root}/.Xauthority" ]; then
    export XAUTHORITY="${HOME}/.Xauthority"
fi

# ── Prevenção de duplicata ────────────────────────────────────────────────────
if pgrep -x i3lock >/dev/null 2>&1 || pgrep -x flavos-lockscreen >/dev/null 2>&1; then
    echo "$(date -Is) INFO: locker já ativo." >> "$LOG"
    exit 0
fi

# ── Tentar lock screen premium ────────────────────────────────────────────────
if command -v python3 >/dev/null 2>&1 && [ -x /usr/local/bin/flavos-lockscreen ]; then
    echo "$(date -Is) INFO: Iniciando flavos-lockscreen." >> "$LOG"
    exec python3 /usr/local/bin/flavos-lockscreen
fi

# ── Fallback: i3lock ──────────────────────────────────────────────────────────
if command -v i3lock >/dev/null 2>&1; then
    echo "$(date -Is) WARN: flavos-lockscreen indisponível — usando i3lock." >> "$LOG"
    exec i3lock -n -c 0D1017
fi

echo "$(date -Is) ERRO: nenhum locker disponível." >> "$LOG"
exit 1
