#!/usr/bin/env bash
#
# flavos-live-media-check
# Etapa 14H.0 — Verificador de Integridade da Mídia Live
#
# Verifica se a mídia Live Boot está íntegra antes de qualquer instalação.
# Somente leitura. Não monta/desmonta discos. Não usa comandos destrutivos.
#
# Uso:
#   flavos-live-media-check --quick    Diagnóstico rápido (dmesg + amostra)
#   flavos-live-media-check --full     Verificação completa (sha256 ou leitura total)
#   flavos-live-media-check            Padrão: --quick

set -euo pipefail

RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
RESET='\033[0m'

MODE="${1:---quick}"
ERRORS=0

echo -e "${BLUE}=== Flavos OS — Verificação de Integridade da Mídia Live ===${RESET}"
echo ""

# ── 1. Verificar se está em ambiente Live ──────────────────────────────────────

check_live_environment() {
    if [ -d "/run/live/medium" ] || [ -d "/lib/live/mount/medium" ]; then
        echo -e "${GREEN}✓ Ambiente Live detectado.${RESET}"
        return 0
    else
        echo -e "${YELLOW}⚠ Não parece ser um ambiente Live Boot.${RESET}"
        echo "  Este script é projetado para validar a mídia Live antes da instalação."
        echo "  Continuando mesmo assim para diagnóstico..."
        return 0
    fi
}

# ── 2. Localizar o SquashFS ────────────────────────────────────────────────────

locate_squashfs() {
    SQUASHFS_MOUNT=$(findmnt -n -t squashfs -o TARGET 2>/dev/null | head -n 1)
    SQUASHFS_SOURCE=$(findmnt -n -t squashfs -o SOURCE 2>/dev/null | head -n 1)

    if [ -n "$SQUASHFS_MOUNT" ]; then
        echo -e "${GREEN}✓ SquashFS montado em: ${SQUASHFS_MOUNT}${RESET}"
        echo "  Fonte: ${SQUASHFS_SOURCE:-desconhecida}"
        return 0
    else
        echo -e "${RED}✗ Nenhum SquashFS montado encontrado.${RESET}"
        ERRORS=$((ERRORS + 1))
        return 1
    fi
}

# ── 3. Verificar data/hora do sistema ──────────────────────────────────────────

check_system_time() {
    echo ""
    echo -e "${BLUE}[Data/Hora]${RESET}"

    CURRENT_YEAR=$(date +%Y)
    CURRENT_DATE=$(date "+%Y-%m-%d %H:%M:%S")
    echo "  Data atual: $CURRENT_DATE"

    if [ "$CURRENT_YEAR" -lt 2025 ] || [ "$CURRENT_YEAR" -gt 2030 ]; then
        echo -e "${RED}✗ Data do sistema parece incorreta (ano: ${CURRENT_YEAR}).${RESET}"
        echo "  Isso pode causar falha no apt update e verificação de certificados."
        echo "  Consulte: docs/APT_TIME_SYNC_RECOVERY.md"
        ERRORS=$((ERRORS + 1))
    else
        echo -e "${GREEN}✓ Data do sistema parece razoável.${RESET}"
    fi
}

# ── 4. Verificar logs do kernel ────────────────────────────────────────────────

check_kernel_logs() {
    echo ""
    echo -e "${BLUE}[Logs do Kernel]${RESET}"

    local squash_errors=0
    local io_errors=0

    if dmesg 2>/dev/null | grep -qiE "SQUASHFS error"; then
        squash_errors=$(dmesg 2>/dev/null | grep -ciE "SQUASHFS error" || true)
        echo -e "${RED}✗ Encontrados ${squash_errors} erros de SquashFS no kernel log.${RESET}"
        dmesg 2>/dev/null | grep -iE "SQUASHFS error" | tail -5
        ERRORS=$((ERRORS + 1))
    else
        echo -e "${GREEN}✓ Nenhum erro de SquashFS no kernel log.${RESET}"
    fi

    if dmesg 2>/dev/null | grep -qiE "I/O error|Input.output error|failed verification"; then
        io_errors=$(dmesg 2>/dev/null | grep -ciE "I/O error|Input.output error|failed verification" || true)
        echo -e "${RED}✗ Encontrados ${io_errors} erros de I/O no kernel log.${RESET}"
        dmesg 2>/dev/null | grep -iE "I/O error|Input.output error|failed verification" | tail -5
        ERRORS=$((ERRORS + 1))
    else
        echo -e "${GREEN}✓ Nenhum erro de I/O no kernel log.${RESET}"
    fi
}

# ── 5. Leitura de amostra (--quick) ───────────────────────────────────────────

quick_read_test() {
    echo ""
    echo -e "${BLUE}[Teste de Leitura Rápida]${RESET}"

    if [ -z "${SQUASHFS_SOURCE:-}" ]; then
        echo -e "${YELLOW}⚠ Sem fonte SquashFS para testar.${RESET}"
        return 0
    fi

    # Tentar ler os primeiros 40 MB do squashfs
    if [ -f "$SQUASHFS_SOURCE" ] || [ -b "$SQUASHFS_SOURCE" ]; then
        if dd if="$SQUASHFS_SOURCE" of=/dev/null bs=4M count=10 2>/dev/null; then
            echo -e "${GREEN}✓ Leitura de amostra (40 MB) bem-sucedida.${RESET}"
        else
            echo -e "${RED}✗ Falha na leitura de amostra. Mídia pode estar corrompida.${RESET}"
            ERRORS=$((ERRORS + 1))
        fi
    else
        # Tentar ler arquivos do mountpoint
        local file_count=0
        local fail_count=0
        while IFS= read -r f; do
            file_count=$((file_count + 1))
            if ! cat "$f" > /dev/null 2>&1; then
                fail_count=$((fail_count + 1))
            fi
            [ "$file_count" -ge 50 ] && break
        done < <(find "$SQUASHFS_MOUNT" -type f 2>/dev/null | head -50)

        if [ "$fail_count" -gt 0 ]; then
            echo -e "${RED}✗ ${fail_count}/${file_count} arquivos falharam na leitura.${RESET}"
            ERRORS=$((ERRORS + 1))
        else
            echo -e "${GREEN}✓ ${file_count} arquivos lidos sem erro.${RESET}"
        fi
    fi
}

# ── 6. Verificação completa (--full) ──────────────────────────────────────────

full_verification() {
    echo ""
    echo -e "${BLUE}[Verificação Completa]${RESET}"

    # Tentar verificação via sha256 primeiro
    local LIVE_MEDIUM=""
    if [ -d "/run/live/medium" ]; then
        LIVE_MEDIUM="/run/live/medium"
    elif [ -d "/lib/live/mount/medium" ]; then
        LIVE_MEDIUM="/lib/live/mount/medium"
    fi

    local SQUASHFS_FILE=""
    local SHA256_FILE=""

    if [ -n "$LIVE_MEDIUM" ]; then
        SQUASHFS_FILE=$(find "$LIVE_MEDIUM" -name "filesystem.squashfs" 2>/dev/null | head -1)
        SHA256_FILE=$(find "$LIVE_MEDIUM" -name "filesystem.squashfs.sha256" 2>/dev/null | head -1)
    fi

    if [ -n "$SHA256_FILE" ] && [ -f "$SHA256_FILE" ] && [ -n "$SQUASHFS_FILE" ] && [ -f "$SQUASHFS_FILE" ]; then
        echo "  Verificando checksum SHA256 do filesystem.squashfs..."
        echo "  Isso pode levar vários minutos."
        local SQUASHFS_DIR
        SQUASHFS_DIR=$(dirname "$SQUASHFS_FILE")
        if (cd "$SQUASHFS_DIR" && sha256sum -c "$SHA256_FILE"); then
            echo -e "${GREEN}✓ Checksum SHA256 verificado com sucesso.${RESET}"
        else
            echo -e "${RED}✗ Checksum SHA256 NÃO confere. Mídia corrompida!${RESET}"
            ERRORS=$((ERRORS + 1))
        fi
    elif [ -n "$SQUASHFS_FILE" ] && [ -f "$SQUASHFS_FILE" ]; then
        echo "  Arquivo .sha256 não encontrado na mídia."
        echo "  Fazendo leitura completa do filesystem.squashfs..."
        echo "  Isso pode levar vários minutos."
        local SIZE_MB
        SIZE_MB=$(du -m "$SQUASHFS_FILE" 2>/dev/null | awk '{print $1}')
        echo "  Tamanho: ${SIZE_MB:-?} MB"
        if dd if="$SQUASHFS_FILE" of=/dev/null bs=4M status=progress 2>&1; then
            echo -e "${GREEN}✓ Leitura completa do squashfs sem erros de I/O.${RESET}"
        else
            echo -e "${RED}✗ Falha na leitura completa. Mídia corrompida!${RESET}"
            ERRORS=$((ERRORS + 1))
        fi
    else
        echo -e "${YELLOW}⚠ Não foi possível localizar filesystem.squashfs para verificação completa.${RESET}"
        echo "  Tentando leitura sequencial via mountpoint..."

        if [ -n "${SQUASHFS_MOUNT:-}" ]; then
            local total=0
            local failed=0
            echo "  Lendo todos os arquivos do squashfs (pode demorar)..."
            while IFS= read -r f; do
                total=$((total + 1))
                if ! cat "$f" > /dev/null 2>&1; then
                    failed=$((failed + 1))
                    echo -e "  ${RED}FALHA: $f${RESET}"
                fi
                if [ $((total % 1000)) -eq 0 ]; then
                    echo "  ... $total arquivos verificados, $failed falhas"
                fi
            done < <(find "$SQUASHFS_MOUNT" -type f 2>/dev/null)

            echo ""
            echo "  Total: $total arquivos, $failed falhas"
            if [ "$failed" -gt 0 ]; then
                echo -e "${RED}✗ ${failed} arquivos com erro de leitura.${RESET}"
                ERRORS=$((ERRORS + 1))
            else
                echo -e "${GREEN}✓ Todos os $total arquivos lidos sem erro.${RESET}"
            fi
        else
            echo -e "${RED}✗ Sem mountpoint para verificação. Abortando.${RESET}"
            ERRORS=$((ERRORS + 1))
        fi
    fi
}

# ── Main ──────────────────────────────────────────────────────────────────────

check_live_environment
locate_squashfs || true
check_system_time
check_kernel_logs

case "$MODE" in
    --quick)
        quick_read_test
        ;;
    --full)
        quick_read_test
        full_verification
        ;;
    *)
        echo -e "${RED}Uso: flavos-live-media-check [--quick|--full]${RESET}"
        exit 1
        ;;
esac

# ── Resultado Final ───────────────────────────────────────────────────────────

echo ""
echo "========================================="
if [ "$ERRORS" -gt 0 ]; then
    echo -e "${RED}RESULTADO: ${ERRORS} problema(s) encontrado(s).${RESET}"
    echo -e "${RED}NÃO instale a partir desta mídia.${RESET}"
    echo ""
    echo "Ações recomendadas:"
    echo "  1. Trocar o pendrive"
    echo "  2. Trocar a porta USB (preferir traseira/USB 2.0)"
    echo "  3. Regravar a ISO após verificar checksum"
    echo "  4. Consultar docs/PHYSICAL_INSTALL_PRECHECK.md"
    echo "========================================="
    exit 1
else
    echo -e "${GREEN}RESULTADO: Mídia Live parece íntegra.${RESET}"
    if [ "$MODE" = "--quick" ]; then
        echo -e "${YELLOW}Nota: Esta foi uma verificação rápida.${RESET}"
        echo "  Para verificação completa antes da instalação: flavos-live-media-check --full"
    fi
    echo "========================================="
    exit 0
fi
