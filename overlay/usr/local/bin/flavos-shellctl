#!/bin/bash
# Flavos OS — Shell Control (flavos-shellctl)
# Camada Agnostica de Middleware para a Interface
#
# Evita chamadas diretas como `openbox --exit` ou `feh` nos aplicativos da shell.
# O frontend Python só conhece este contrato. Subjacente a ele o sistema roteia.

set -e

ACTION="$1"
SUB_ACTION="$2"
PARAM="$3"

usage() {
    echo "Uso: flavos-shellctl <ação> <sub-ação> [parâmetros]"
    echo ""
    echo "Sessão:"
    echo "  session lock     Bloqueia a tela da sessão local (xsecurelock)"
    echo "  session logout   Encerra efetivamente toda a sessão visual (loginctl/pkill)"
    echo "  session reboot   Reinicia o sistema via systemd"
    echo "  session poweroff Desliga o sistema via systemd"
    echo ""
    echo "Instância (Soft):"
    echo "  shell restart    Reinicia os middlewares visuais sem deslogar (Tint2, Picom)"
    echo ""
    echo "Orquestração Visual:"
    echo "  wallpaper apply <path>"
    echo "                   Aplica papel de parede via contrato global da sessão"
    exit 1
}

# -----------------
# CONTROLE DE SESSÃO
# -----------------
if [ "$ACTION" = "session" ]; then
    if [ "$SUB_ACTION" = "logout" ]; then
        # Usa primariamente o logind (limpo, destrói TTY visual e volta pro LightDM/TTY1)
        if [ -n "$XDG_SESSION_ID" ]; then
            loginctl terminate-session "$XDG_SESSION_ID" 2>/dev/null || true
        fi
        
        # Fallback forçado caso logind falhe (mata WM atual, openbox ou wayland compositor)
        if [ "$XDG_SESSION_TYPE" = "x11" ]; then
            openbox --exit 2>/dev/null || killall openbox 2>/dev/null || true
        else
            # Logout sem DBus: matar sessão atual encerando os processos X11 do usuário
            kill -TERM -1 2>/dev/null || true 
        fi
        exit 0

    elif [ "$SUB_ACTION" = "lock" ]; then
        if [ "${XDG_SESSION_TYPE:-x11}" != "x11" ]; then
            echo "Erro: lock via xsecurelock só está implementado para X11 nesta fase."
            exit 1
        fi

        if ! command -v xsecurelock >/dev/null 2>&1; then
            echo "Erro: xsecurelock não está instalado."
            exit 1
        fi

        if pgrep -x xsecurelock >/dev/null 2>&1; then
            echo "Lock screen já está ativo."
            exit 0
        fi

        export DISPLAY="${DISPLAY:-:0}"

        if [ -z "${XAUTHORITY:-}" ] && [ -f "$HOME/.Xauthority" ]; then
            export XAUTHORITY="$HOME/.Xauthority"
        fi

        export XSECURELOCK_PASSWORD_PROMPT=asterisks
        export XSECURELOCK_SAVER=saver_blank

        # Flavos OS Design System — cores e tipografia
        export XSECURELOCK_BACKGROUND_COLOR="#0D1017"
        export XSECURELOCK_AUTH_BACKGROUND_COLOR="#0D1017"
        export XSECURELOCK_AUTH_FOREGROUND_COLOR="#E8ECF4"
        export XSECURELOCK_AUTH_WARNING_COLOR="#F87171"
        export XSECURELOCK_FONT="Inter:size=14"
        export XSECURELOCK_SHOW_USERNAME=1
        export XSECURELOCK_SHOW_HOSTNAME=0
        export XSECURELOCK_SHOW_DATETIME=1
        export XSECURELOCK_DATETIME_FORMAT="%H:%M"

        ( umask 077; xsecurelock >/tmp/flavos-xsecurelock.log 2>&1 ) &
        sleep 0.3

        if pgrep -x xsecurelock >/dev/null 2>&1; then
            exit 0
        else
            echo "Erro: xsecurelock falhou ao iniciar. Veja /tmp/flavos-xsecurelock.log"
            exit 1
        fi

    elif [ "$SUB_ACTION" = "reboot" ]; then
        systemctl reboot
        exit 0

    elif [ "$SUB_ACTION" = "poweroff" ]; then
        systemctl poweroff
        exit 0
    else
        usage
    fi
fi

# -----------------
# RESTART DE INSTÂNCIA 
# -----------------
# Mata e ressurge processos que decoram a sessão atual (Não desloga o usuário)
if [ "$ACTION" = "shell" ] && [ "$SUB_ACTION" = "restart" ]; then
    if [ "$XDG_SESSION_TYPE" = "x11" ]; then
        echo "Reiniciando componentes X11 via systemd UI daemon..."
        systemctl --user reload-or-restart flavos-shell.service
        exit 0
    else
        echo "AÇÃO shell restart em WAYLAND AINDA NÃO IMPLEMENTADA."
        exit 0
    fi
fi

# -----------------
# ORQUESTRAÇÃO VISUAL & UI
# -----------------
if [ "$ACTION" = "launcher" ]; then
    if [ "$SUB_ACTION" = "toggle" ] || [ "$SUB_ACTION" = "open" ]; then
        # ── Toggle baseado em PID file — contrato atômico com flavos-launcher ──
        # Razão: pgrep retorna exit 1 (falharia com set -e) e não garante que
        # o processo está visível. O PID file é escrito pelo launcher ao iniciar
        # e removido ao sair, sendo a fonte de verdade do estado do launcher.
        LAUNCHER_PID_FILE="/tmp/flavos-launcher.pid"

        if [ -f "$LAUNCHER_PID_FILE" ]; then
            # Lê o PID armazenado
            STORED_PID=""
            STORED_PID=$(cat "$LAUNCHER_PID_FILE" 2>/dev/null) || true

            if [ -n "$STORED_PID" ] && kill -0 "$STORED_PID" 2>/dev/null; then
                # Processo vivo → fechar via SIGTERM (dispara fade-out limpo no launcher)
                kill -TERM "$STORED_PID" || true
                exit 0
            else
                # PID stale: processo morreu sem limpar o arquivo → remover e reabrir
                rm -f "$LAUNCHER_PID_FILE"
            fi
        fi

        # Launcher não está ativo → abrir
        export DISPLAY="${DISPLAY:-:0}"
        /usr/local/bin/flavos-launcher &
        exit 0
    fi
fi

if [ "$ACTION" = "wallpaper" ] && [ "$SUB_ACTION" = "apply" ]; then
    if [ -z "$PARAM" ] || [ ! -f "$PARAM" ]; then
        echo "Erro: Caminho para imagem de wallpaper inválido."
        exit 1
    fi

    # Sanitiza o path para evitar injeção via metacaracteres
    PARAM="$(realpath -- "$PARAM" 2>/dev/null)" || { echo "Erro: path inválido."; exit 1; }
    
    # Salva o contrato em cache para reloads futuros
    mkdir -p "$HOME/.config/flavos"
    echo "$PARAM" > "$HOME/.config/flavos/wallpaper"

    if [ "$XDG_SESSION_TYPE" = "x11" ] || [ -z "$XDG_SESSION_TYPE" ]; then
        # Nemo-desktop lê wallpaper via gsettings (org.cinnamon.desktop.background)
        # Tenta o schema do Cinnamon (nemo-desktop), depois GNOME, depois fallback feh
        if gsettings set org.cinnamon.desktop.background picture-uri "file://${PARAM}" 2>/dev/null; then
            gsettings set org.cinnamon.desktop.background picture-options "zoom" 2>/dev/null
        elif gsettings set org.gnome.desktop.background picture-uri "file://${PARAM}" 2>/dev/null; then
            gsettings set org.gnome.desktop.background picture-options "zoom" 2>/dev/null
        else
            # Fallback: feh direto (sem nemo-desktop gerenciando root window)
            feh --no-fehbg --bg-fill "$PARAM" 2>/dev/null || true
        fi
    else
        # Espaço reservado para o compositor Wayland (swaybg / wpaperd)
        echo "AÇÃO wallpaper apply pronta pra Wayland backend (stub)."
    fi
    exit 0
fi

usage
