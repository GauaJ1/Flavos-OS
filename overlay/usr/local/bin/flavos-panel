#!/usr/bin/env python3
# Flavos Native Panel (Etapa 11B)
# Componente Core da Shell. Controlado via flavos-session-daemon.
# Atua usando Hint de DOCK provisório no X11.

import gi
import os
import subprocess
import time
import json
from datetime import datetime

gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk, GLib

CONFIG_PATH = os.path.expanduser("~/.config/flavos/panel.json")

def load_config():
    if os.path.exists(CONFIG_PATH):
        try:
            with open(CONFIG_PATH, "r") as f:
                return json.load(f)
        except:
            pass
    return {"opacity": 100, "alignment": "left", "style": "solid"}

# CSS Base — usa {alpha} no modo glass e cor sólida no solid
BASE_CSS_SOLID = """
#FlavosPanel {
    background-color: #0D1017;
    border-bottom: 2px solid #272D3D;
}
button.panel-btn {
    background-image: none;
    background-color: transparent;
    border: none;
    box-shadow: none;
    color: #8891A5;
    font-family: Inter, sans-serif;
    font-weight: 700;
    font-size: 13px;
    padding-left: 14px;
    padding-right: 14px;
    border-radius: 8px;
    margin-top: 4px;
    margin-bottom: 4px;
    transition: all 0.2s ease-in-out;
}
button.panel-btn:hover {
    background-image: none;
    background-color: #232838;
    color: #E8ECF4;
}
button.panel-btn:active, button.panel-btn.active {
    background-image: none;
    background-color: #4B8BF5;
    color: #FFFFFF;
}
button.launcher { color: #FFFFFF; }
label.clock {
    font-family: Inter, sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #E8ECF4;
}
"""

BASE_CSS_GLASS = """
#FlavosPanel {{
    background-color: rgba(13, 16, 23, {alpha});
    border-bottom: 2px solid rgba(39, 45, 61, {alpha});
}}
button.panel-btn {{
    background-image: none;
    background-color: transparent;
    border: none;
    box-shadow: none;
    color: #8891A5;
    font-family: Inter, sans-serif;
    font-weight: 700;
    font-size: 13px;
    padding-left: 14px;
    padding-right: 14px;
    border-radius: 8px;
    margin-top: 4px;
    margin-bottom: 4px;
    transition: all 0.2s ease-in-out;
}}
button.panel-btn:hover {{
    background-image: none;
    background-color: rgba(35, 40, 56, {hover_alpha});
    color: #E8ECF4;
}}
button.panel-btn:active, button.panel-btn.active {{
    background-image: none;
    background-color: #4B8BF5;
    color: #FFFFFF;
}}
button.launcher {{ color: #FFFFFF; }}
label.clock {{
    font-family: Inter, sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #E8ECF4;
}}
"""

def spawn_async(cmd_list):
    """Cria um processo de subprocess invisível à engine Gtk para invocar as ferramentas."""
    subprocess.Popen(cmd_list, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


class FlavosPanel(Gtk.Window):
    def __init__(self):
        super().__init__(type=Gtk.WindowType.TOPLEVEL)
        self.set_name("FlavosPanel")
        
        # Hint de DOCK: solução de transição X11 (ver regra 11B)
        if os.environ.get("XDG_SESSION_TYPE", "x11") == "x11":
            self.set_type_hint(Gdk.WindowTypeHint.DOCK)

        self.set_decorated(False)
        self.set_resizable(False)
        self.set_accept_focus(False)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)

        # Lendo Configuração viva de Painel
        cfg = load_config()
        style = cfg.get("style", "solid")   # "solid" | "glass"
        opacity = cfg.get("opacity", 100)
        align = cfg.get("alignment", "left")

        # RGBA visual: só ativado no modo glass com compositor ativo
        if os.environ.get("XDG_SESSION_TYPE", "x11") == "x11" and style == "glass":
            self.set_app_paintable(True)
            screen = self.get_screen()
            visual = screen.get_rgba_visual()
            if visual and screen.is_composited():
                self.set_visual(visual)

        # CSS condicional por modo
        if style == "glass":
            alpha_val = float(opacity) / 100.0
            hover_alpha_val = min(1.0, alpha_val + 0.25)
            css_str = BASE_CSS_GLASS.format(alpha=alpha_val, hover_alpha=hover_alpha_val)
        else:
            css_str = BASE_CSS_SOLID

        provider = Gtk.CssProvider()
        provider.load_from_data(css_str.encode("utf-8"))
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_USER
        )

        display = Gdk.Display.get_default()
        monitor = display.get_primary_monitor() or display.get_monitor(0)
        geom = monitor.get_geometry()

        # Layout horizontal expandível até o limite do monitor
        main_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        self.add(main_box)

        # ====== ESQUERDA: LAUNCHER (BRANDING) ======
        # Convertido de Gtk.Button para Gtk.Label por decisão arquitetural.
        left_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        lbl_branding = Gtk.Label(label="FLAVOS")
        # Mantemos as classes panel-btn nativas para herdarem alinhamento, mas reforçamos como label puro
        lbl_branding.get_style_context().add_class("panel-btn")
        lbl_branding.get_style_context().add_class("launcher")
        # Removido o evento de clique e o pseudo-foco do OS.
        # ====== CENTRO: DATA/HORA ======
        center_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        self.lbl_clock = Gtk.Label()
        self.lbl_clock.get_style_context().add_class("clock")
        
        if align == "center":
            center_box.pack_start(lbl_branding, False, False, 0)
        else:
            left_box.pack_start(lbl_branding, False, False, 4)
            main_box.pack_start(left_box, False, False, 8)
            
        center_box.pack_start(self.lbl_clock, True, True, 0)
        
        # Fill/Expand central empurra os extremos
        main_box.set_center_widget(center_box)
        
        self.update_clock()
        GLib.timeout_add_seconds(1, self.update_clock)

        # ====== DIREITA: OPÇÕES / SYSTRAY WRAPPER ======
        right_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        
        btn_settings = Gtk.Button()
        btn_settings.get_style_context().add_class("panel-btn")
        icon_set = Gtk.Image.new_from_icon_name("emblem-system-symbolic", Gtk.IconSize.MENU)
        btn_settings.add(icon_set)
        btn_settings.connect("clicked", lambda _: spawn_async(["flavos-settings"]))
        
        btn_power = Gtk.Button()
        btn_power.get_style_context().add_class("panel-btn")
        icon_pwr = Gtk.Image.new_from_icon_name("system-shutdown-symbolic", Gtk.IconSize.MENU)
        btn_power.add(icon_pwr)
        btn_power.connect("clicked", lambda _: spawn_async(["flavos-power"]))
        
        # Ícones "dummy" funcionais restaurados para rede e áudio, mapeando para o Settings (Sistematização sem Systray Gtk3 legado)
        btn_net = Gtk.Button()
        btn_net.get_style_context().add_class("panel-btn")
        btn_net.add(Gtk.Image.new_from_icon_name("network-wireless-symbolic", Gtk.IconSize.MENU))
        btn_net.connect("clicked", lambda _: spawn_async(["nm-connection-editor"]))
        
        btn_vol = Gtk.Button()
        btn_vol.get_style_context().add_class("panel-btn")
        btn_vol.add(Gtk.Image.new_from_icon_name("audio-volume-high-symbolic", Gtk.IconSize.MENU))
        btn_vol.connect("clicked", lambda _: spawn_async(["pavucontrol"]))

        right_box.pack_end(btn_power, False, False, 4)
        right_box.pack_end(btn_settings, False, False, 0)
        right_box.pack_end(btn_net, False, False, 0)
        right_box.pack_end(btn_vol, False, False, 0)
        
        main_box.pack_end(right_box, False, False, 8)

        # Painel ancorado no TOPO do monitor
        self.set_default_size(geom.width, 36)
        self.move(geom.x, geom.y)

    def update_clock(self):
        now = datetime.now()
        # Formato com data + relógio 
        self.lbl_clock.set_text(now.strftime("%a, %d %b • %H:%M").title())
        return True


if __name__ == "__main__":
    win = FlavosPanel()
    win.show_all()
    Gtk.main()
