#!/usr/bin/env python3
# Flavos OS — Power Menu v4
# Janela POPUP com fundo TRANSPARENTE (Picom gerencia cantos/sombra).
# O CSS sólido fica apenas no box interno (.power-surface).

import gi
import os
import subprocess
import shlex
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk

CSS = b"""
* {
    outline-style: none;
    outline-width: 0;
}
window {
    background-color: transparent;
}
.power-surface {
    background-color: #0D1017;
    border: 1px solid #272D3D;
    border-radius: 12px;
    padding-top: 20px;
    padding-bottom: 16px;
    padding-left: 20px;
    padding-right: 20px;
}
label {
    color: #E8ECF4;
    font-family: Inter, sans-serif;
    background-color: transparent;
}
label.heading {
    font-size: 11px;
    font-weight: 700;
    color: #8891A5;
    letter-spacing: 1px;
    margin-bottom: 8px;
}
button {
    background-image: none;
    background-color: #1C2030;
    color: #E8ECF4;
    border-radius: 8px;
    border: 1px solid #272D3D;
    font-family: Inter, sans-serif;
    font-weight: 600;
    font-size: 13px;
    padding: 12px 16px;
    margin-bottom: 4px;
    box-shadow: none;
    text-shadow: none;
}
button label {
    color: #E8ECF4;
    background-color: transparent;
}
button:hover {
    background-image: none;
    background-color: #232838;
}
button:hover label {
    color: #E8ECF4;
}
button:active {
    background-image: none;
    background-color: #4B8BF5;
}
button:active label {
    color: #FFFFFF;
}
button.danger label {
    color: #F87171;
}
button.danger:hover {
    background-image: none;
    background-color: #F87171;
    border-color: #F87171;
}
button.danger:hover label {
    color: #FFFFFF;
}
button.cancel {
    background-image: none;
    background-color: transparent;
    border-color: transparent;
}
button.cancel label {
    color: #8891A5;
}
button.cancel:hover {
    background-image: none;
    background-color: #1C2030;
    border-color: #272D3D;
}
button.cancel:hover label {
    color: #E8ECF4;
}
separator {
    background-color: #272D3D;
    min-height: 1px;
    margin-top: 4px;
    margin-bottom: 4px;
}
"""


def run_async(cmd):
    """Executa comando assíncrono sem bloquear o loop GTK.
    Usa shlex.split para evitar shell=True (segurança)."""
    subprocess.Popen(shlex.split(cmd))


class PowerMenu(Gtk.Window):
    def __init__(self):
        super().__init__(title="Menu de Energia")
        self.set_decorated(False)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.set_default_size(300, -1)
        self.set_resizable(False)
        # Seções de hack do X11 mantidas condicionalmente para o Xorg/Picom
        if os.environ.get("XDG_SESSION_TYPE", "x11") == "x11":
            self.set_keep_above(True)
            self.set_app_paintable(True)
            screen = self.get_screen()
            visual = screen.get_rgba_visual()
            if visual and screen.is_composited():
                self.set_visual(visual)

        css_provider = Gtk.CssProvider()
        css_provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_USER
        )

        self.connect("key-press-event", self._on_key)
        self.connect("focus-out-event", lambda w, e: self.destroy())

        # Surface interna — recebe o fundo sólido e bordas via .power-surface
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        vbox.get_style_context().add_class("power-surface")
        self.add(vbox)

        heading = Gtk.Label(label="ENERGIA", xalign=0)
        heading.get_style_context().add_class("heading")
        vbox.pack_start(heading, False, False, 0)

        actions = [
            ("Bloquear",        None,     "/usr/local/bin/flavos-shellctl session lock"),
            ("Desligar",        "danger", "flavos-shellctl session poweroff"),
            ("Reiniciar",       None,     "flavos-shellctl session reboot"),
            ("Suspender",       None,     "systemctl suspend"),
            ("Encerrar Sessão", None,     "flavos-shellctl session logout"),
        ]

        for label, css_class, cmd in actions:
            btn = Gtk.Button(label=label)
            if css_class:
                btn.get_style_context().add_class(css_class)
            btn.connect("clicked", lambda _w, c=cmd: [run_async(c), self.destroy()])
            vbox.pack_start(btn, False, False, 0)

        sep = Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL)
        vbox.pack_start(sep, False, False, 0)

        btn_cancel = Gtk.Button(label="Cancelar")
        btn_cancel.get_style_context().add_class("cancel")
        btn_cancel.connect("clicked", lambda _: self.destroy())
        vbox.pack_start(btn_cancel, False, False, 0)

    def _on_key(self, widget, event):
        if event.keyval == Gdk.KEY_Escape:
            self.destroy()
            return True
        return False


if __name__ == "__main__":
    win = PowerMenu()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()
