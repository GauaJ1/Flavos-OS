#!/usr/bin/env python3
# Flavos OS — Shell Session Daemon v2
# Mantém os pilares visuais da Shell (Native Shell Core - Etapa 11)
# Roda via systemd --user no boot grafico.

import subprocess
import time
import signal
import sys
import os

processes = {}

# Pilares visuais supervisionados (watchdog revive se morrerem)
COMMANDS = {
    "compositor": ["picom"],
    "main_panel": ["flavos-panel"],
    "taskbar": ["flavos-taskbar"],
    "notifications": ["dunst"],
    "desktop": ["pcmanfm", "--desktop"]
}

# Processos "fire-and-forget": sobem uma vez, fazem fork interno, não são supervisionados.
# O xcape faz fork() e o pai retorna exit 0 imediatamente — isso é comportamento normal,
# não crash. Tentar revivê-lo causa loop infinito de respawn.
FIRE_AND_FORGET = {
    "xcape": ["xcape", "-e", "Super_L=Alt_L|F1"]
}

def spawn(name):
    """Inicia um node visual se não estiver ativo."""
    if name in processes and processes[name].poll() is None:
         return
    print(f"[flavos-shell] Iniciando node: {name}", flush=True)
    # Redireciona stderr para log — crashes silenciosos são indiagnosticáveis
    log_path = os.path.expanduser(f"~/.local/share/flavos/logs/{name}.log")
    os.makedirs(os.path.dirname(log_path), exist_ok=True)
    log_fd = open(log_path, "a")
    processes[name] = subprocess.Popen(
        COMMANDS[name],
        stdout=subprocess.DEVNULL,
        stderr=log_fd
    )

def spawn_fire_and_forget(name):
    """Inicia processo que faz fork interno. Não será supervisionado."""
    print(f"[flavos-shell] Fire-and-forget: {name}", flush=True)
    subprocess.Popen(
        FIRE_AND_FORGET[name],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL
    )

def spawn_delayed(name, delay=2.0):
    """Inicia um node visual com atraso para garantir que X11/WM subiu."""
    if name in processes and processes[name].poll() is None:
         return
    print(f"[flavos-shell] Iniciando node com delay ({delay}s): {name}", flush=True)
    time.sleep(delay)
    spawn(name)

def stop_all():
    """Mata todos os filhos elegantemente."""
    print("[flavos-shell] Encerrando nodes supervisionados...", flush=True)
    for name, p in processes.items():
        if p.poll() is None:
            p.terminate()
            try:
                p.wait(timeout=2)
            except subprocess.TimeoutExpired:
                p.kill()

def handle_term(signum, frame):
    stop_all()
    sys.exit(0)

def handle_hup(signum, frame):
    print("[flavos-shell] Recebido SIGHUP (Reload). Reiniciando nodes...", flush=True)
    stop_all()
    for name in COMMANDS:
        spawn(name)

signal.signal(signal.SIGTERM, handle_term)
signal.signal(signal.SIGINT, handle_term)
signal.signal(signal.SIGHUP, handle_hup)

if __name__ == "__main__":
    print("[flavos-shell] Daemon Ativado. Assumindo a Shell UI...", flush=True)
    
    # 1. Core visual (compositor + painel superior + desktop + notificações)
    for name in ["compositor", "main_panel", "desktop", "notifications"]:
        spawn(name)
    
    # 2. Taskbar com delay — Wnck precisa do WM estabilizado
    spawn_delayed("taskbar", 1.5)
    
    # 3. xcape — fire-and-forget, sobe DEPOIS do Openbox estar pronto
    #    O delay da taskbar já garante ~1.5s. xcape precisa do WM para capturar.
    spawn_fire_and_forget("xcape")
    
    # 4. Watchdog loop — só supervisiona COMMANDS, não fire-and-forget
    while True:
        try:
            time.sleep(2)
        except InterruptedError:
            continue
            
        for name in COMMANDS:
             if processes.get(name) and processes[name].poll() is not None:
                 print(f"[flavos-shell] Node morta ({name}). Revivendo...", flush=True)
                 spawn(name)
