[Desktop Entry]
Name=Visualizador de Imagens
Comment=Visualize suas fotos e imagens
Exec=viewnior %U
Icon=image-viewer
Terminal=false
Type=Application
StartupNotify=true
MimeType=image/bmp;image/gif;image/jpeg;image/png;image/tiff;image/x-bmp;image/x-ms-bmp;image/x-portable-anymap;image/x-portable-bitmap;image/x-portable-graymap;image/x-portable-pixmap;image/x-tga;image/x-xbitmap;image/svg+xml;image/webp;
Categories=Graphics;Viewer;
