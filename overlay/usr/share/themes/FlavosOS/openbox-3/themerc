# Flavos OS — Openbox Window Theme v3
# Tokens: canvas=#0D1017 surface=#151921 elevated=#1C2030
#          overlay=#232838 accent=#4B8BF5 border=#272D3D
#          fg.primary=#E8ECF4 fg.secondary=#8891A5 fg.muted=#505872

# --- Active Window ---
window.active.title.bg: flat solid
window.active.title.bg.color: #1C2030
window.active.label.text.color: #E8ECF4
window.active.label.text.font: shadow=n

# --- Inactive Window ---
window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #0D1017
window.inactive.label.text.color: #8891A5

# --- Handle / Grip ---
window.active.handle.bg: flat solid
window.active.handle.bg.color: #1C2030
window.inactive.handle.bg: flat solid
window.inactive.handle.bg.color: #0D1017
window.handle.width: 0

window.active.grip.bg: flat solid
window.active.grip.bg.color: #1C2030
window.inactive.grip.bg: flat solid
window.inactive.grip.bg.color: #0D1017

# --- Borders ---
window.active.client.color: #151921
window.inactive.client.color: #0D1017
window.active.border.color: #272D3D
window.inactive.border.color: #151921
border.width: 1
padding.width: 6
padding.height: 5

# --- Active Buttons ---
window.active.button.unpressed.bg: flat solid
window.active.button.unpressed.bg.color: #1C2030
window.active.button.unpressed.image.color: #8891A5

window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: #232838
window.active.button.hover.image.color: #E8ECF4

window.active.button.pressed.bg: flat solid
window.active.button.pressed.bg.color: #4B8BF5
window.active.button.pressed.image.color: #ffffff

window.active.button.disabled.bg: flat solid
window.active.button.disabled.bg.color: #1C2030
window.active.button.disabled.image.color: #505872

# --- Inactive Buttons ---
window.inactive.button.unpressed.bg: flat solid
window.inactive.button.unpressed.bg.color: #0D1017
window.inactive.button.unpressed.image.color: #505872

window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: #151921
window.inactive.button.hover.image.color: #8891A5

# --- WM Menu (right-click) ---
menu.title.bg: flat solid
menu.title.bg.color: #151921
menu.title.text.color: #E8ECF4
menu.title.text.font: shadow=n

menu.items.bg: flat solid
menu.items.bg.color: #151921
menu.items.text.color: #8891A5
menu.items.disabled.text.color: #505872

menu.items.active.bg: flat solid
menu.items.active.bg.color: #232838
menu.items.active.text.color: #E8ECF4

menu.separator.color: #272D3D
menu.separator.width: 1
menu.separator.padding.width: 8
menu.separator.padding.height: 6

# --- OSD ---
osd.bg: flat solid
osd.bg.color: #151921
osd.label.text.color: #E8ECF4
osd.border.color: #272D3D
osd.border.width: 1
