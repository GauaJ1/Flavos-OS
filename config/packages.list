# Flavos OS — Pacotes a instalar no rootfs (via apt no chroot)
# Um pacote por linha. Linhas começando com # são ignoradas.

# Kernel
linux-image-amd64

# Boot
systemd-boot
initramfs-tools
efibootmgr

# Init e serviços
systemd
systemd-sysv
dbus

# Utilitários base
bash
coreutils
nano
less
curl
htop
iproute2
iputils-ping
kmod
procps

# Serviços essenciais
openssh-server
sudo
kmod

# Rede
iproute2
iputils-ping
systemd-resolved

# Filesystem
e2fsprogs
dosfstools

# Locale
locales

# Extras úteis para debug
grep
sed
gawk
findutils
file
mount

# Suporte a hardware legad e QA (Etapa 7)
gpm
evtest
efibootmgr

# Fundação Gráfica (Etapa 9A)
xserver-xorg-core
xserver-xorg-video-all
xserver-xorg-input-all
xinit
openbox
x11-xserver-utils

# Shell Visual (Etapa 9B)
# Apps Nativos Essenciais (Etapa 10C / 12B)
kitty
nemo
dconf-cli
mousepad
viewnior
xdg-utils
shared-mime-info
librsvg2-common
libglib2.0-bin
neofetch

lxpolkit
libpam-systemd
feh
picom
fonts-inter
fonts-roboto
papirus-icon-theme

# Flavos Settings (Etapa 9C)
python3
python3-gi
gir1.2-gtk-3.0
gir1.2-wnck-3.0

# Serviços Visuais da Shell e Applets de Sistema (Etapa 10B/10C)
dunst
libnotify-bin
alsa-utils
pulseaudio
pulseaudio-utils
network-manager
network-manager-gnome
volumeicon-alsa
xfce4-power-manager
xfce4-clipman

# Sistema de Controle de Energia e Bateria (Etapa 10D)
acpi

# Polkit para helpers privilegiados (Etapa 10D)
policykit-1

# Super key mapping X11 (Etapa 11B)
xcape

# Clipboard X11
xclip

# Controle de brilho (Etapa 11D — opcional, fallback para /sys/class/backlight)
brightnessctl

# ─── Etapa 12A — Navegador Padrão e Web Experience ────────────────────────────
# Navegador: Firefox ESR
# Justificativa: pacote LTS do Debian, GTK nativo, integração xdg-open, ícone Papirus.
# NÃO instalar via snap. Usar somente apt dentro do chroot.
firefox-esr

# ─── Etapa 12D — Media, Playback & Daily Usability Polish ─────────────────────
# PDF: evince (GTK3, poppler backend, disponível no Debian Bookworm)
# Nota: xreader NÃO está nos repos Bookworm (exclusivo Linux Mint)
evince
# Media: Celluloid (frontend GTK3 para mpv — puxa mpv como dep automaticamente)
# Cobre video/mp4, video/webm, video/mkv, audio/mpeg, audio/flac, etc.
celluloid

# ─── Etapa 12F — Performance Adaptation & Resource Profiles ─────────────────
# systemd-zram-generator: suporte a swap comprimida em RAM (zstd)
# Disponível no Debian Bookworm. Instalado para disponibilidade.
# NÃO ativo por padrão. Ativar com:
#   flavos-performance-profile set light --with-zram   (requer sudo)
# Docs: /etc/flavos/performance-profile + docs/PERFORMANCE_PROFILES.md
systemd-zram-generator
# mesa-utils: contém glxinfo, usado pelo flavos-performance-profile para
# detectar suporte GLX real antes de ativar backend glx no Picom (perfil Full).
mesa-utils

# ─── Etapa 13A — Archive & Compression Support ──────────────────────────────
# Suporte integrado ao desktop usando ferramentas maduras Linux/GTK.
# Integrado ao Nemo para menus "Extrair Aqui" e "Comprimir...".
file-roller
nemo-fileroller
zip
unzip
p7zip-full
unrar-free

# ─── Etapa 13B — User Directories & Download Flow ───────────────────────────
# Padronização de diretórios XDG do usuário (Desktop, Downloads, etc).
# NÃO incluir xdg-user-dirs-gtk para evitar traduções indesejadas dos caminhos.
xdg-user-dirs

# ─── Etapa 13C — Lock Screen & Session Security ──────────────────────────────
# Backend atual: flavos-lockscreen (Python GTK, 13C.3) → fallback i3lock
# xsecurelock testado em 13C.1/13C.2, abandonado por vazamento visual com Picom.
# Ref: docs/SESSION_LOCK_AND_SECURITY.md
i3lock
# flavos-lockscreen deps:
python3-pam     # autenticação PAM no lock screen customizado
python3-cairo   # Cairo para GTK3 draw callbacks (Recommends do python3-gi, mas excluído por --no-install-recommends)
scrot           # captura de tela para fundo desfocado
imagemagick     # blur da captura de tela
