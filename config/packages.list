# Flavos OS — Pacotes a instalar no rootfs (via apt no chroot)
# Um pacote por linha. Linhas começando com # são ignoradas.

# Kernel
linux-image-amd64

# Boot
systemd-boot
initramfs-tools
efibootmgr

# Init e serviços
systemd
systemd-sysv
dbus

# Utilitários base
bash
coreutils
nano
less
curl
htop
iproute2
iputils-ping
kmod
procps

# Serviços essenciais
openssh-server
sudo
kmod

# Rede
iproute2
iputils-ping
systemd-resolved

# Filesystem
e2fsprogs
dosfstools

# Locale
locales

# Extras úteis para debug
grep
sed
gawk
findutils
file
mount

# Suporte a hardware legad e QA (Etapa 7)
gpm
evtest
efibootmgr

# Fundação Gráfica (Etapa 9A)
xserver-xorg-core
xserver-xorg-video-all
xserver-xorg-input-all
xinit
openbox
x11-xserver-utils

# Shell Visual (Etapa 9B)
# Apps Nativos Essenciais (Etapa 10C / 12B)
kitty
nemo
dconf-cli
mousepad
viewnior
xdg-utils
shared-mime-info
librsvg2-common
libglib2.0-bin
neofetch

lxpolkit
libpam-systemd
feh
picom
fonts-inter
fonts-roboto
papirus-icon-theme

