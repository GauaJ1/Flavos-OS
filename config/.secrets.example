# Flavos OS — Credenciais de Build (Template)
#
# Copie este arquivo para config/.secrets e preencha com suas credenciais:
#   cp config/.secrets.example config/.secrets
#
# O arquivo config/.secrets é gitignored e NUNCA deve ser commitado.
#
# Para desenvolvimento local, as credenciais padrão são:
#   ROOT_PASSWORD="flavos"
#   SYS_PASSWORD="123"
#
# Para qualquer publicação ou uso em rede não controlada,
# substitua por credenciais fortes ANTES do build.

# Senha do root (apenas para emergência via console)
ROOT_PASSWORD="CHANGE_ME"

# Usuário primário do sistema
SYS_USER="flavos"
SYS_PASSWORD="CHANGE_ME"
